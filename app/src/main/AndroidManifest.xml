<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <queries>
        <package android:name="com.binance.dev" />
        <package android:name="com.binance" />
        <package android:name="com.binance.app" />
        <package android:name="com.binance.client" />
        <package android:name="com.binance.mobile" />
        <package android:name="com.binance.mgs" />
        <package android:name="com.binance.us" />
        <package android:name="net.metaquotes.metatrader5" />
        <package android:name="com.metatrader5.mobile" />
    </queries>

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <application
        android:name=".BinanceMonitorApp"
        android:allowBackup="true"
        android:icon="@drawable/ic_monitor_logo"
        android:label="@string/app_name"
        android:networkSecurityConfig="@xml/network_security_config"
        android:roundIcon="@drawable/ic_monitor_logo"
        android:supportsRtl="true"
        android:theme="@style/Theme.BinanceMonitor"
        android:usesCleartextTraffic="true">

        <activity
            android:name=".ui.log.LogActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <activity
            android:name=".ui.account.AccountStatsBridgeActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <activity
            android:name=".ui.chart.MarketChartActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <activity
            android:name=".ui.settings.SettingsActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <activity
            android:name=".ui.settings.SettingsSectionActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <activity
            android:name=".ui.main.MainActivity"
            android:exported="true"
            android:screenOrientation="portrait" />

        <activity-alias
            android:name=".launcher.IconFinancialAlias"
            android:enabled="true"
            android:exported="true"
            android:icon="@drawable/ic_monitor_logo"
            android:label="@string/app_name"
            android:roundIcon="@drawable/ic_monitor_logo"
            android:targetActivity=".ui.main.MainActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

        <activity-alias
            android:name=".launcher.IconVintageAlias"
            android:enabled="false"
            android:exported="true"
            android:icon="@drawable/ic_monitor_logo"
            android:label="@string/app_name"
            android:roundIcon="@drawable/ic_monitor_logo"
            android:targetActivity=".ui.main.MainActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

        <activity-alias
            android:name=".launcher.IconBinanceAlias"
            android:enabled="false"
            android:exported="true"
            android:icon="@drawable/ic_monitor_logo"
            android:label="@string/app_name"
            android:roundIcon="@drawable/ic_monitor_logo"
            android:targetActivity=".ui.main.MainActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

        <activity-alias
            android:name=".launcher.IconTradingViewAlias"
            android:enabled="false"
            android:exported="true"
            android:icon="@drawable/ic_monitor_logo"
            android:label="@string/app_name"
            android:roundIcon="@drawable/ic_monitor_logo"
            android:targetActivity=".ui.main.MainActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

        <activity-alias
            android:name=".launcher.IconLightAlias"
            android:enabled="false"
            android:exported="true"
            android:icon="@drawable/ic_monitor_logo"
            android:label="@string/app_name"
            android:roundIcon="@drawable/ic_monitor_logo"
            android:targetActivity=".ui.main.MainActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

        <service
            android:name=".service.MonitorService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

        <receiver
            android:name=".receiver.BootCompletedReceiver"
            android:enabled="true"
            android:exported="false">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
                <action android:name="android.intent.action.QUICKBOOT_POWERON" />
            </intent-filter>
        </receiver>
    </application>

</manifest>
