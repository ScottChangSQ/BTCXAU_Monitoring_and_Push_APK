<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <corners android:radius="@dimen/radius_sm" />
            <solid android:color="@color/accent_gold" />
            <stroke
                android:width="1dp"
                android:color="@color/accent_blue" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="@dimen/radius_sm" />
            <solid android:color="@color/bg_card" />
            <stroke
                android:width="1dp"
                android:color="@color/stroke_card" />
        </shape>
    </item>
</selector>
