<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app"
    android:orientation="vertical">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:padding="@dimen/page_horizontal_padding">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_8"
                android:text="设置"
                android:textAppearance="@style/TextAppearance.BinanceMonitor.SectionTitle" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="点击分类进入下一级页面"
                android:textAppearance="@style/TextAppearance.BinanceMonitor.Caption" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_16"
                android:text="常规设置"
                android:textAppearance="@style/TextAppearance.BinanceMonitor.Caption" />

            <LinearLayout
                android:id="@+id/itemDisplay"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="@dimen/space_8"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="@dimen/page_horizontal_padding"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackgroundBorderless">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="悬浮窗与显示"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp" />

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginStart="@dimen/space_8"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_chevron_right"
                    android:tint="@color/text_secondary" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginStart="@dimen/page_horizontal_padding"
                android:background="@color/divider" />

            <LinearLayout
                android:id="@+id/itemGateway"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="@dimen/space_2"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="@dimen/page_horizontal_padding"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackgroundBorderless">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="MT5 网关地址"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp" />

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginStart="@dimen/space_8"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_chevron_right"
                    android:tint="@color/text_secondary" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginStart="@dimen/page_horizontal_padding"
                android:background="@color/divider" />

            <LinearLayout
                android:id="@+id/itemTheme"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="@dimen/space_2"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="@dimen/page_horizontal_padding"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackgroundBorderless">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="主题设置"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp" />

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginStart="@dimen/space_8"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_chevron_right"
                    android:tint="@color/text_secondary" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginStart="@dimen/page_horizontal_padding"
                android:background="@color/divider" />

            <View
                android:layout_width="match_parent"
                android:layout_height="12dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="辅助工具"
                android:textAppearance="@style/TextAppearance.BinanceMonitor.Caption" />

            <LinearLayout
                android:id="@+id/itemTab"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="@dimen/space_8"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="@dimen/page_horizontal_padding"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackgroundBorderless">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Tab 页管理"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp" />

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginStart="@dimen/space_8"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_chevron_right"
                    android:tint="@color/text_secondary" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginStart="@dimen/page_horizontal_padding"
                android:background="@color/divider" />

            <LinearLayout
                android:id="@+id/itemCache"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="@dimen/space_2"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="@dimen/page_horizontal_padding"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackgroundBorderless">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="缓存管理"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp" />

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginStart="@dimen/space_8"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_chevron_right"
                    android:tint="@color/text_secondary" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginStart="@dimen/page_horizontal_padding"
                android:background="@color/divider" />

            <LinearLayout
                android:id="@+id/itemLogs"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="@dimen/space_2"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="@dimen/page_horizontal_padding"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackgroundBorderless">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="运行日志"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp" />

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginStart="@dimen/space_8"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_chevron_right"
                    android:tint="@color/text_secondary" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="@dimen/space_20" />
        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/tabBar"
        android:layout_width="match_parent"
        android:layout_height="@dimen/bottom_nav_height"
        android:background="@drawable/bg_bottom_nav"
        android:orientation="horizontal"
        android:padding="0dp">

        <TextView
            android:id="@+id/tabMarketMonitor"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@drawable/bg_tab_wechat_unselected"
            android:gravity="center"
            android:text="@string/nav_market_monitor"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tabMarketChart"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@drawable/bg_tab_wechat_unselected"
            android:gravity="center"
            android:text="@string/nav_market_chart"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tabAccountStats"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@drawable/bg_tab_wechat_unselected"
            android:gravity="center"
            android:text="@string/nav_account_stats"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tabSettings"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@drawable/bg_tab_wechat_selected"
            android:gravity="center"
            android:text="设置"
            android:textColor="@color/white"
            android:textSize="13sp"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>
