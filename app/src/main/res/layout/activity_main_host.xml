<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <FrameLayout
        android:id="@+id/hostFragmentContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <LinearLayout
        android:id="@+id/hostBottomNavigation"
        android:layout_width="match_parent"
        android:layout_height="@dimen/bottom_nav_height"
        android:background="@android:color/transparent"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="0dp">

        <TextView
            android:id="@+id/tabTrading"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:drawablePadding="@dimen/inline_gap_compact"
            android:gravity="center"
            android:includeFontPadding="false"
            android:maxLines="1"
            android:paddingTop="@dimen/row_gap"
            android:paddingBottom="@dimen/row_gap_compact"
            android:text="@string/nav_trading"
            android:textAppearance="@style/TextAppearance.BinanceMonitor.Tiny" />

        <TextView
            android:id="@+id/tabAccount"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:drawablePadding="@dimen/inline_gap_compact"
            android:gravity="center"
            android:includeFontPadding="false"
            android:maxLines="1"
            android:paddingTop="@dimen/row_gap"
            android:paddingBottom="@dimen/row_gap_compact"
            android:text="@string/nav_account"
            android:textAppearance="@style/TextAppearance.BinanceMonitor.Tiny" />

        <TextView
            android:id="@+id/tabAnalysis"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:drawablePadding="@dimen/inline_gap_compact"
            android:gravity="center"
            android:includeFontPadding="false"
            android:maxLines="1"
            android:paddingTop="@dimen/row_gap"
            android:paddingBottom="@dimen/row_gap_compact"
            android:text="@string/nav_analysis"
            android:textAppearance="@style/TextAppearance.BinanceMonitor.Tiny" />
    </LinearLayout>
</LinearLayout>
