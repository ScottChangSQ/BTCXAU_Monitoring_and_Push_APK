<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app"
    android:orientation="vertical">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingStart="2dp"
            android:paddingTop="2dp"
            android:paddingEnd="2dp"
            android:paddingBottom="2dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/cardSymbolPanel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:orientation="vertical"
                android:padding="2dp">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/control_height_md">

                    <androidx.appcompat.widget.AppCompatSpinner
                        android:id="@+id/spinnerSymbolPicker"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_spinner_filter"
                        android:minWidth="0dp"
                        android:popupBackground="@drawable/bg_spinner_popup"
                        android:spinnerMode="dropdown" />

                    <TextView
                        android:id="@+id/tvChartSymbolPickerLabel"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:clickable="true"
                        android:ellipsize="end"
                        android:focusable="true"
                        android:gravity="center_vertical|start"
                        android:includeFontPadding="false"
                        android:maxLines="1"
                        android:paddingStart="@dimen/space_12"
                        android:paddingEnd="32dp"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp" />
                </FrameLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/cardChartPanel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:orientation="vertical"
                android:padding="2dp">

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="30dp"
                    android:scrollbars="none">

                    <LinearLayout
                        android:id="@+id/layoutIntervalTabs"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:background="@android:color/transparent"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="@dimen/space_4"
                        android:paddingEnd="@dimen/space_4">

                        <Button
                            android:id="@+id/btnInterval1m"
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:background="@android:color/transparent"
                            android:minWidth="0dp"
                            android:paddingStart="@dimen/space_8"
                            android:paddingEnd="@dimen/space_8"
                            android:text="1分"
                            android:textAllCaps="false"
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp" />

                        <Button
                            android:id="@+id/btnInterval5m"
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:background="@android:color/transparent"
                            android:minWidth="0dp"
                            android:paddingStart="@dimen/space_8"
                            android:paddingEnd="@dimen/space_8"
                            android:text="5分"
                            android:textAllCaps="false"
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp" />

                        <Button
                            android:id="@+id/btnInterval15m"
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:background="@android:color/transparent"
                            android:minWidth="0dp"
                            android:paddingStart="@dimen/space_8"
                            android:paddingEnd="@dimen/space_8"
                            android:text="15分"
                            android:textAllCaps="false"
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp" />

                        <Button
                            android:id="@+id/btnInterval30m"
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:background="@android:color/transparent"
                            android:minWidth="0dp"
                            android:paddingStart="@dimen/space_8"
                            android:paddingEnd="@dimen/space_8"
                            android:text="30分"
                            android:textAllCaps="false"
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp" />

                        <Button
                            android:id="@+id/btnInterval1h"
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:background="@android:color/transparent"
                            android:minWidth="0dp"
                            android:paddingStart="@dimen/space_8"
                            android:paddingEnd="@dimen/space_8"
                            android:text="1小时"
                            android:textAllCaps="false"
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp" />

                        <Button
                            android:id="@+id/btnInterval4h"
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:background="@android:color/transparent"
                            android:minWidth="0dp"
                            android:paddingStart="@dimen/space_8"
                            android:paddingEnd="@dimen/space_8"
                            android:text="4小时"
                            android:textAllCaps="false"
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp" />

                        <Button
                            android:id="@+id/btnInterval1d"
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:background="@android:color/transparent"
                            android:minWidth="0dp"
                            android:paddingStart="@dimen/space_8"
                            android:paddingEnd="@dimen/space_8"
                            android:text="日线"
                            android:textAllCaps="false"
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp" />

                        <Button
                            android:id="@+id/btnInterval1w"
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:background="@android:color/transparent"
                            android:minWidth="0dp"
                            android:paddingStart="@dimen/space_8"
                            android:paddingEnd="@dimen/space_8"
                            android:text="周线"
                            android:textAllCaps="false"
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp" />

                        <Button
                            android:id="@+id/btnInterval1mo"
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:background="@android:color/transparent"
                            android:minWidth="0dp"
                            android:paddingStart="@dimen/space_8"
                            android:paddingEnd="@dimen/space_8"
                            android:text="月线"
                            android:textAllCaps="false"
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp" />

                        <Button
                            android:id="@+id/btnInterval1y"
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:background="@android:color/transparent"
                            android:minWidth="0dp"
                            android:paddingStart="@dimen/space_8"
                            android:paddingEnd="@dimen/space_8"
                            android:text="年线"
                            android:textAllCaps="false"
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp" />
                    </LinearLayout>
                </HorizontalScrollView>

                <TextView
                    android:id="@+id/tvChartInfo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_8"
                    android:text="@string/chart_info_empty"
                    android:textAppearance="@style/TextAppearance.BinanceMonitor.Meta"
                    android:visibility="gone" />

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="460dp"
                    android:layout_marginTop="@dimen/space_8">

                    <com.binance.monitor.ui.chart.KlineChartView
                        android:id="@+id/klineChartView"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent" />

                    <TextView
                        android:id="@+id/tvChartRefreshCountdown"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="end|top"
                        android:layout_marginEnd="4dp"
                        android:layout_marginTop="4dp"
                        android:includeFontPadding="false"
                        android:text="--ms"
                        android:textAppearance="@style/TextAppearance.BinanceMonitor.Meta"
                        android:textSize="9sp" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="end|top"
                        android:layout_marginTop="4dp"
                        android:layout_marginEnd="4dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <ProgressBar
                            android:id="@+id/progressChart"
                            style="?android:attr/progressBarStyleSmall"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:visibility="gone" />

                        <TextView
                            android:id="@+id/tvChartLoading"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/space_4"
                            android:text="@string/chart_loading_overlay_text"
                            android:textAppearance="@style/TextAppearance.BinanceMonitor.Meta"
                            android:visibility="gone" />
                    </LinearLayout>

                    <ImageButton
                        android:id="@+id/btnScrollToLatest"
                        android:layout_width="25dp"
                        android:layout_height="25dp"
                        android:layout_gravity="bottom|end"
                        android:layout_marginEnd="2dp"
                        android:layout_marginBottom="2dp"
                        android:background="@drawable/bg_scroll_to_latest"
                        android:contentDescription="@string/chart_back_to_latest"
                        android:padding="4dp"
                        android:scaleType="centerInside"
                        android:src="@drawable/ic_scroll_to_latest_arrow"
                        android:tint="@color/text_primary"
                        android:visibility="invisible" />

                    <Button
                        android:id="@+id/btnTogglePositionOverlays"
                        android:layout_width="wrap_content"
                        android:layout_height="25dp"
                        android:layout_gravity="top|start"
                        android:background="@android:color/transparent"
                        android:minWidth="0dp"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp"
                        android:text="@string/chart_position_overlays_on"
                        android:textAllCaps="false"
                        android:textColor="@color/text_primary"
                        android:textSize="10sp" />

                    <Button
                        android:id="@+id/btnToggleHistoryTrades"
                        android:layout_width="wrap_content"
                        android:layout_height="25dp"
                        android:layout_gravity="top|start"
                        android:background="@android:color/transparent"
                        android:minWidth="0dp"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp"
                        android:text="@string/chart_history_trades_on"
                        android:textAllCaps="false"
                        android:textColor="@color/text_primary"
                        android:textSize="10sp" />
                </FrameLayout>

                <TextView
                    android:id="@+id/tvChartState"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text=""
                    android:textAppearance="@style/TextAppearance.BinanceMonitor.Caption" />

                <TextView
                    android:id="@+id/tvError"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textColor="@color/accent_red"
                    android:textAppearance="@style/TextAppearance.BinanceMonitor.Caption"
                    android:visibility="gone" />

                <Button
                    android:id="@+id/btnRetryLoad"
                    android:layout_width="wrap_content"
                    android:layout_height="@dimen/control_height_sm"
                    android:layout_marginTop="4dp"
                    android:background="@drawable/bg_chip_selected"
                    android:text="重试加载"
                    android:textAllCaps="false"
                    android:textColor="@color/white"
                    android:textSize="11sp"
                    android:visibility="gone" />

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="30dp"
                    android:layout_marginTop="4dp"
                    android:scrollbars="none">

                    <LinearLayout
                        android:id="@+id/layoutIndicatorTabs"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:background="@android:color/transparent"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="@dimen/space_4"
                        android:paddingEnd="@dimen/space_4">

                        <Button
                            android:id="@+id/btnIndicatorVolume"
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:background="@android:color/transparent"
                            android:minWidth="0dp"
                            android:paddingStart="@dimen/space_12"
                            android:paddingEnd="@dimen/space_12"
                            android:text="VOL"
                            android:textAllCaps="false"
                            android:textColor="@color/text_secondary"
                            android:textSize="10sp" />

                        <Button
                            android:id="@+id/btnIndicatorMacd"
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:background="@android:color/transparent"
                            android:minWidth="0dp"
                            android:paddingStart="@dimen/space_12"
                            android:paddingEnd="@dimen/space_12"
                            android:text="MACD"
                            android:textAllCaps="false"
                            android:textColor="@color/text_secondary"
                            android:textSize="10sp" />

                        <Button
                            android:id="@+id/btnIndicatorStochRsi"
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:background="@android:color/transparent"
                            android:minWidth="0dp"
                            android:paddingStart="@dimen/space_12"
                            android:paddingEnd="@dimen/space_12"
                            android:text="STOCHRSI"
                            android:textAllCaps="false"
                            android:textColor="@color/text_secondary"
                            android:textSize="10sp" />

                        <Button
                            android:id="@+id/btnIndicatorBoll"
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:background="@android:color/transparent"
                            android:minWidth="0dp"
                            android:paddingStart="@dimen/space_12"
                            android:paddingEnd="@dimen/space_12"
                            android:text="BOLL"
                            android:textAllCaps="false"
                            android:textColor="@color/text_secondary"
                            android:textSize="10sp" />

                        <Button
                            android:id="@+id/btnIndicatorMa"
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:background="@android:color/transparent"
                            android:minWidth="0dp"
                            android:paddingStart="@dimen/space_12"
                            android:paddingEnd="@dimen/space_12"
                            android:text="MA"
                            android:textAllCaps="false"
                            android:textColor="@color/text_secondary"
                            android:textSize="10sp" />

                        <Button
                            android:id="@+id/btnIndicatorEma"
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:background="@android:color/transparent"
                            android:minWidth="0dp"
                            android:paddingStart="@dimen/space_12"
                            android:paddingEnd="@dimen/space_12"
                            android:text="EMA"
                            android:textAllCaps="false"
                            android:textColor="@color/text_secondary"
                            android:textSize="10sp" />

                        <Button
                            android:id="@+id/btnIndicatorSra"
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:background="@android:color/transparent"
                            android:minWidth="0dp"
                            android:paddingStart="@dimen/space_12"
                            android:paddingEnd="@dimen/space_12"
                            android:text="SRA"
                            android:textAllCaps="false"
                            android:textColor="@color/text_secondary"
                            android:textSize="10sp" />

                        <Button
                            android:id="@+id/btnIndicatorAvl"
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:background="@android:color/transparent"
                            android:minWidth="0dp"
                            android:paddingStart="@dimen/space_12"
                            android:paddingEnd="@dimen/space_12"
                            android:text="AVL"
                            android:textAllCaps="false"
                            android:textColor="@color/text_secondary"
                            android:textSize="10sp" />

                        <Button
                            android:id="@+id/btnIndicatorRsi"
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:background="@android:color/transparent"
                            android:minWidth="0dp"
                            android:paddingStart="@dimen/space_12"
                            android:paddingEnd="@dimen/space_12"
                            android:text="RSI"
                            android:textAllCaps="false"
                            android:textColor="@color/text_secondary"
                            android:textSize="10sp" />

                        <Button
                            android:id="@+id/btnIndicatorKdj"
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:background="@android:color/transparent"
                            android:minWidth="0dp"
                            android:paddingStart="@dimen/space_12"
                            android:paddingEnd="@dimen/space_12"
                            android:text="KDJ"
                            android:textAllCaps="false"
                            android:textColor="@color/text_secondary"
                            android:textSize="10sp" />
                    </LinearLayout>
                </HorizontalScrollView>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/cardChartPositions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:orientation="vertical"
                android:padding="8dp">

                <TextView
                    android:id="@+id/tvChartPositionTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="当前持仓"
                    android:textAppearance="@style/TextAppearance.BinanceMonitor.Body" />

                <TextView
                    android:id="@+id/tvChartPositionSummary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="持仓盈亏: -- | 持仓收益率: --"
                    android:textAppearance="@style/TextAppearance.BinanceMonitor.Caption" />

                <LinearLayout
                    android:id="@+id/layoutChartPositionRows"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:orientation="horizontal"
                    android:visibility="visible">

                    <Button
                        android:id="@+id/btnChartTradeBuy"
                        android:layout_width="0dp"
                        android:layout_height="@dimen/control_height_sm"
                        android:layout_weight="1"
                        android:background="@android:color/transparent"
                        android:minWidth="0dp"
                        android:text="买入"
                        android:textAllCaps="false"
                        android:textColor="@color/text_primary"
                        android:textSize="10sp" />

                    <Button
                        android:id="@+id/btnChartTradeSell"
                        android:layout_width="0dp"
                        android:layout_height="@dimen/control_height_sm"
                        android:layout_marginStart="6dp"
                        android:layout_weight="1"
                        android:background="@android:color/transparent"
                        android:minWidth="0dp"
                        android:text="卖出"
                        android:textAllCaps="false"
                        android:textColor="@color/text_primary"
                        android:textSize="10sp" />

                    <Button
                        android:id="@+id/btnChartTradePending"
                        android:layout_width="0dp"
                        android:layout_height="@dimen/control_height_sm"
                        android:layout_marginStart="6dp"
                        android:layout_weight="1"
                        android:background="@android:color/transparent"
                        android:minWidth="0dp"
                        android:text="挂单"
                        android:textAllCaps="false"
                        android:textColor="@color/text_primary"
                        android:textSize="10sp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvChartPositionAggregateTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="按产品汇总"
                    android:textAppearance="@style/TextAppearance.BinanceMonitor.SectionLabel" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recyclerChartPositionByProduct"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:nestedScrollingEnabled="false" />

                <TextView
                    android:id="@+id/tvChartPositionAggregateEmpty"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="暂无持仓"
                    android:textAppearance="@style/TextAppearance.BinanceMonitor.Meta"
                    android:visibility="gone" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tvChartPositionDetailTitle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="持仓明细"
                        android:textAppearance="@style/TextAppearance.BinanceMonitor.SectionLabel" />

                    <FrameLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp">

                        <androidx.appcompat.widget.AppCompatSpinner
                            android:id="@+id/spinnerChartPositionSort"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:alpha="0.01"
                            android:background="@android:color/transparent"
                            android:dropDownWidth="wrap_content"
                            android:minWidth="0dp"
                            android:popupBackground="@drawable/bg_spinner_popup"
                            android:spinnerMode="dropdown" />

                        <TextView
                            android:id="@+id/tvChartPositionSortLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="end|center_vertical"
                            android:clickable="true"
                            android:ellipsize="end"
                            android:focusable="true"
                            android:gravity="center_vertical|end"
                            android:includeFontPadding="false"
                            android:maxLines="1"
                            android:padding="0dp"
                            android:text="开仓时间（倒序）"
                            android:textColor="@color/text_primary"
                            android:textAppearance="@style/TextAppearance.BinanceMonitor.SectionLabel" />
                    </FrameLayout>
                </LinearLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recyclerChartPositions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:nestedScrollingEnabled="false" />

                <TextView
                    android:id="@+id/tvChartPositionsEmpty"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="暂无持仓"
                    android:textAppearance="@style/TextAppearance.BinanceMonitor.Meta"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/tvChartPendingOrdersTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="挂单明细"
                    android:textAppearance="@style/TextAppearance.BinanceMonitor.SectionLabel" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recyclerChartPendingOrders"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:nestedScrollingEnabled="false" />

                <TextView
                    android:id="@+id/tvChartPendingOrdersEmpty"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="暂无挂单"
                    android:textAppearance="@style/TextAppearance.BinanceMonitor.Meta"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/tvChartOverviewTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="账户总览"
                    android:textAppearance="@style/TextAppearance.BinanceMonitor.Body" />

                <TextView
                    android:id="@+id/tvChartOverviewMeta"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="更新时间 --"
                    android:textAppearance="@style/TextAppearance.BinanceMonitor.Meta" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recyclerChartOverview"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:nestedScrollingEnabled="false" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="4dp" />
        </LinearLayout>
        </androidx.core.widget.NestedScrollView>

