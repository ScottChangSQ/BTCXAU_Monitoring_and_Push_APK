<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app"
    android:orientation="vertical">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingStart="0dp"
            android:paddingTop="@dimen/space_2"
            android:paddingEnd="0dp"
            android:paddingBottom="@dimen/space_2">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/cardSymbolPanel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/bg_card"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="@dimen/page_horizontal_padding"
                android:paddingEnd="@dimen/page_horizontal_padding"
                android:paddingTop="@dimen/space_2"
                android:paddingBottom="@dimen/space_2">

                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="@dimen/control_height_lg"
                    android:layout_weight="1.08"
                    android:layout_marginEnd="@dimen/control_group_gap">

                    <androidx.appcompat.widget.AppCompatSpinner
                        android:id="@+id/spinnerSymbolPicker"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_spinner_filter"
                        android:minWidth="0dp"
                        android:popupBackground="@drawable/bg_spinner_popup"
                        android:spinnerMode="dropdown" />

                    <TextView
                        android:id="@+id/tvChartSymbolPickerLabel"
                        style="@style/Widget.BinanceMonitor.Spinner.Label"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:clickable="true"
                        android:focusable="true"
                        android:paddingStart="@dimen/space_8"
                        android:paddingEnd="28dp"
                        android:textAppearance="@style/TextAppearance.BinanceMonitor.Control" />
                </FrameLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnChartModeMarket"
                    style="@style/Widget.BinanceMonitor.Button.SecondaryContentSquare"
                    android:layout_width="wrap_content"
                    android:layout_height="@dimen/control_height_lg"
                    android:layout_marginEnd="@dimen/control_group_gap"
                    android:text="@string/chart_mode_market" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnChartModePending"
                    style="@style/Widget.BinanceMonitor.Button.SecondaryContentSquare"
                    android:layout_width="wrap_content"
                    android:layout_height="@dimen/control_height_lg"
                    android:layout_marginEnd="@dimen/control_group_gap"
                    android:text="@string/chart_mode_pending" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnGlobalStatus"
                    style="@style/Widget.BinanceMonitor.Button.SecondaryContentSquare"
                    android:layout_width="wrap_content"
                    android:layout_height="@dimen/control_height_lg"
                    android:text="@string/global_status_button_offline" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/cardChartPanel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/page_section_gap"
                android:background="@color/bg_card"
                android:orientation="vertical"
                android:padding="@dimen/card_content_padding">

                <LinearLayout
                    android:id="@+id/layoutChartQuickTradeBar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/space_2"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="3dp"
                    android:paddingEnd="3dp"
                    android:visibility="gone">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnQuickTradePrimary"
                        style="@style/Widget.BinanceMonitor.Button.SecondaryContentSquare"
                        android:layout_width="0dp"
                        android:layout_height="@dimen/control_height_md"
                        android:layout_weight="1"
                        android:text="@string/chart_quick_trade_buy" />

                    <EditText
                        android:id="@+id/etQuickTradeVolume"
                        android:layout_width="@dimen/chart_quick_trade_volume_width"
                        android:layout_height="@dimen/control_height_md"
                        android:layout_marginStart="@dimen/control_group_gap"
                        android:layout_marginEnd="@dimen/control_group_gap"
                        android:gravity="center"
                        android:hint="@string/chart_quick_trade_default_volume"
                        android:importantForAutofill="no"
                        android:includeFontPadding="false"
                        android:inputType="numberDecimal"
                        android:paddingStart="@dimen/space_2"
                        android:paddingEnd="@dimen/space_2"
                        android:text="@string/chart_quick_trade_default_volume"
                        android:textAppearance="@style/TextAppearance.BinanceMonitor.Control"
                        android:textColor="@color/text_primary"
                        android:textSize="13sp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnQuickTradeSecondary"
                        style="@style/Widget.BinanceMonitor.Button.SecondaryContentSquare"
                        android:layout_width="0dp"
                        android:layout_height="@dimen/control_height_md"
                        android:layout_weight="1"
                        android:text="@string/chart_quick_trade_sell" />
                </LinearLayout>

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="30dp"
                    android:background="@color/bg_surface"
                    android:scrollbars="none">

                    <LinearLayout
                        android:id="@+id/layoutIntervalTabs"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:background="@android:color/transparent"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="@dimen/space_4"
                        android:paddingEnd="@dimen/space_4">

                        <Button
                            android:id="@+id/btnInterval1m"
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:background="@android:color/transparent"
                            android:layout_marginEnd="@dimen/control_group_gap"
                            android:minWidth="0dp"
                            android:paddingStart="@dimen/space_8"
                            android:paddingEnd="@dimen/space_8"
                            android:text="1分"
                            android:textAllCaps="false"
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp" />

                        <Button
                            android:id="@+id/btnInterval5m"
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:background="@android:color/transparent"
                            android:layout_marginEnd="@dimen/control_group_gap"
                            android:minWidth="0dp"
                            android:paddingStart="@dimen/space_8"
                            android:paddingEnd="@dimen/space_8"
                            android:text="5分"
                            android:textAllCaps="false"
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp" />

                        <Button
                            android:id="@+id/btnInterval15m"
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:background="@android:color/transparent"
                            android:layout_marginEnd="@dimen/control_group_gap"
                            android:minWidth="0dp"
                            android:paddingStart="@dimen/space_8"
                            android:paddingEnd="@dimen/space_8"
                            android:text="15分"
                            android:textAllCaps="false"
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp" />

                        <Button
                            android:id="@+id/btnInterval30m"
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:background="@android:color/transparent"
                            android:layout_marginEnd="@dimen/control_group_gap"
                            android:minWidth="0dp"
                            android:paddingStart="@dimen/space_8"
                            android:paddingEnd="@dimen/space_8"
                            android:text="30分"
                            android:textAllCaps="false"
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp" />

                        <Button
                            android:id="@+id/btnInterval1h"
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:background="@android:color/transparent"
                            android:layout_marginEnd="@dimen/control_group_gap"
                            android:minWidth="0dp"
                            android:paddingStart="@dimen/space_8"
                            android:paddingEnd="@dimen/space_8"
                            android:text="1小时"
                            android:textAllCaps="false"
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp" />

                        <Button
                            android:id="@+id/btnInterval4h"
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:background="@android:color/transparent"
                            android:layout_marginEnd="@dimen/control_group_gap"
                            android:minWidth="0dp"
                            android:paddingStart="@dimen/space_8"
                            android:paddingEnd="@dimen/space_8"
                            android:text="4小时"
                            android:textAllCaps="false"
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp" />

                        <Button
                            android:id="@+id/btnInterval1d"
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:background="@android:color/transparent"
                            android:layout_marginEnd="@dimen/control_group_gap"
                            android:minWidth="0dp"
                            android:paddingStart="@dimen/space_8"
                            android:paddingEnd="@dimen/space_8"
                            android:text="日线"
                            android:textAllCaps="false"
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp" />

                        <Button
                            android:id="@+id/btnInterval1w"
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:background="@android:color/transparent"
                            android:layout_marginEnd="@dimen/control_group_gap"
                            android:minWidth="0dp"
                            android:paddingStart="@dimen/space_8"
                            android:paddingEnd="@dimen/space_8"
                            android:text="周线"
                            android:textAllCaps="false"
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp" />

                        <Button
                            android:id="@+id/btnInterval1mo"
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:background="@android:color/transparent"
                            android:layout_marginEnd="@dimen/control_group_gap"
                            android:minWidth="0dp"
                            android:paddingStart="@dimen/space_8"
                            android:paddingEnd="@dimen/space_8"
                            android:text="月线"
                            android:textAllCaps="false"
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp" />

                        <Button
                            android:id="@+id/btnInterval1y"
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:background="@android:color/transparent"
                            android:minWidth="0dp"
                            android:paddingStart="@dimen/space_8"
                            android:paddingEnd="@dimen/space_8"
                            android:text="年线"
                            android:textAllCaps="false"
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp" />
                    </LinearLayout>
                </HorizontalScrollView>

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="460dp"
                    android:layout_marginTop="@dimen/space_2">

                    <com.binance.monitor.ui.chart.KlineChartView
                        android:id="@+id/klineChartView"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent" />

                    <TextView
                        android:id="@+id/tvChartPositionSummary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="end|top"
                        android:layout_marginEnd="4dp"
                        android:layout_marginTop="4dp"
                        android:gravity="end"
                        android:includeFontPadding="false"
                        android:text="盈亏：-- | 持仓：--"
                        android:textAlignment="viewEnd"
                        android:textAppearance="@style/TextAppearance.BinanceMonitor.Meta"
                        android:textSize="@dimen/chart_price_info_text_size" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="end|top"
                        android:layout_marginTop="4dp"
                        android:layout_marginEnd="4dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <ProgressBar
                            android:id="@+id/progressChart"
                            style="?android:attr/progressBarStyleSmall"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:visibility="gone" />

                        <TextView
                            android:id="@+id/tvChartLoading"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/space_4"
                            android:text="@string/chart_loading_overlay_text"
                            android:textAppearance="@style/TextAppearance.BinanceMonitor.Meta"
                            android:visibility="gone" />
                    </LinearLayout>

                    <ImageButton
                        android:id="@+id/btnScrollToLatest"
                        android:layout_width="25dp"
                        android:layout_height="25dp"
                        android:layout_gravity="bottom|end"
                        android:layout_marginEnd="2dp"
                        android:layout_marginBottom="2dp"
                        android:background="@drawable/bg_scroll_to_latest"
                        android:contentDescription="@string/chart_back_to_latest"
                        android:padding="4dp"
                        android:scaleType="centerInside"
                        android:src="@drawable/ic_scroll_to_latest_arrow"
                        android:tint="@color/text_primary"
                        android:visibility="invisible" />

                    <Button
                        android:id="@+id/btnToggleHistoryTrades"
                        android:layout_width="wrap_content"
                        android:layout_height="25dp"
                        android:layout_gravity="top|start"
                        android:background="@android:color/transparent"
                        android:minWidth="0dp"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp"
                        android:text="@string/chart_history_trades_on"
                        android:textAllCaps="false"
                        android:textColor="@color/text_primary"
                        android:textSize="10sp" />

                    <Button
                        android:id="@+id/btnTogglePositionOverlays"
                        android:layout_width="wrap_content"
                        android:layout_height="25dp"
                        android:layout_gravity="top|start"
                        android:background="@android:color/transparent"
                        android:minWidth="0dp"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp"
                        android:text="@string/chart_position_overlays_on"
                        android:textAllCaps="false"
                        android:textColor="@color/text_primary"
                        android:textSize="10sp" />
                </FrameLayout>

                <TextView
                    android:id="@+id/tvChartState"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_2"
                    android:text=""
                    android:textAppearance="@style/TextAppearance.BinanceMonitor.Caption" />

                <TextView
                    android:id="@+id/tvError"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_2"
                    android:textColor="@color/accent_red"
                    android:textAppearance="@style/TextAppearance.BinanceMonitor.Caption"
                    android:visibility="gone" />

                <Button
                    android:id="@+id/btnRetryLoad"
                    style="@style/Widget.BinanceMonitor.TextAction.Compact"
                    android:layout_width="wrap_content"
                    android:layout_height="@dimen/control_height_sm"
                    android:layout_marginTop="@dimen/space_2"
                    android:background="@drawable/bg_chip_selected"
                    android:text="重试加载"
                    android:textColor="@color/white"
                    android:visibility="gone" />

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="30dp"
                    android:layout_marginTop="@dimen/space_2"
                    android:background="@color/bg_surface"
                    android:scrollbars="none">

                    <LinearLayout
                        android:id="@+id/layoutIndicatorTabs"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:background="@android:color/transparent"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="@dimen/space_4"
                        android:paddingEnd="@dimen/space_4">

                        <Button
                            android:id="@+id/btnIndicatorVolume"
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:background="@android:color/transparent"
                            android:minWidth="0dp"
                            android:paddingStart="@dimen/space_12"
                            android:paddingEnd="@dimen/space_12"
                            android:text="VOL"
                            android:textAllCaps="false"
                            android:textColor="@color/text_secondary"
                            android:textSize="10sp" />

                        <Button
                            android:id="@+id/btnIndicatorMacd"
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:background="@android:color/transparent"
                            android:minWidth="0dp"
                            android:paddingStart="@dimen/space_12"
                            android:paddingEnd="@dimen/space_12"
                            android:text="MACD"
                            android:textAllCaps="false"
                            android:textColor="@color/text_secondary"
                            android:textSize="10sp" />

                        <Button
                            android:id="@+id/btnIndicatorStochRsi"
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:background="@android:color/transparent"
                            android:minWidth="0dp"
                            android:paddingStart="@dimen/space_12"
                            android:paddingEnd="@dimen/space_12"
                            android:text="STOCHRSI"
                            android:textAllCaps="false"
                            android:textColor="@color/text_secondary"
                            android:textSize="10sp" />

                        <Button
                            android:id="@+id/btnIndicatorBoll"
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:background="@android:color/transparent"
                            android:minWidth="0dp"
                            android:paddingStart="@dimen/space_12"
                            android:paddingEnd="@dimen/space_12"
                            android:text="BOLL"
                            android:textAllCaps="false"
                            android:textColor="@color/text_secondary"
                            android:textSize="10sp" />

                        <Button
                            android:id="@+id/btnIndicatorMa"
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:background="@android:color/transparent"
                            android:minWidth="0dp"
                            android:paddingStart="@dimen/space_12"
                            android:paddingEnd="@dimen/space_12"
                            android:text="MA"
                            android:textAllCaps="false"
                            android:textColor="@color/text_secondary"
                            android:textSize="10sp" />

                        <Button
                            android:id="@+id/btnIndicatorEma"
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:background="@android:color/transparent"
                            android:minWidth="0dp"
                            android:paddingStart="@dimen/space_12"
                            android:paddingEnd="@dimen/space_12"
                            android:text="EMA"
                            android:textAllCaps="false"
                            android:textColor="@color/text_secondary"
                            android:textSize="10sp" />

                        <Button
                            android:id="@+id/btnIndicatorSra"
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:background="@android:color/transparent"
                            android:minWidth="0dp"
                            android:paddingStart="@dimen/space_12"
                            android:paddingEnd="@dimen/space_12"
                            android:text="SRA"
                            android:textAllCaps="false"
                            android:textColor="@color/text_secondary"
                            android:textSize="10sp" />

                        <Button
                            android:id="@+id/btnIndicatorAvl"
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:background="@android:color/transparent"
                            android:minWidth="0dp"
                            android:paddingStart="@dimen/space_12"
                            android:paddingEnd="@dimen/space_12"
                            android:text="AVL"
                            android:textAllCaps="false"
                            android:textColor="@color/text_secondary"
                            android:textSize="10sp" />

                        <Button
                            android:id="@+id/btnIndicatorRsi"
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:background="@android:color/transparent"
                            android:minWidth="0dp"
                            android:paddingStart="@dimen/space_12"
                            android:paddingEnd="@dimen/space_12"
                            android:text="RSI"
                            android:textAllCaps="false"
                            android:textColor="@color/text_secondary"
                            android:textSize="10sp" />

                        <Button
                            android:id="@+id/btnIndicatorKdj"
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:background="@android:color/transparent"
                            android:minWidth="0dp"
                            android:paddingStart="@dimen/space_12"
                            android:paddingEnd="@dimen/space_12"
                            android:text="KDJ"
                            android:textAllCaps="false"
                            android:textColor="@color/text_secondary"
                            android:textSize="10sp" />
                    </LinearLayout>
                </HorizontalScrollView>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="2dp" />
        </LinearLayout>
        </androidx.core.widget.NestedScrollView>

    </FrameLayout>

    <LinearLayout
        android:id="@+id/tabBar"
        android:layout_width="match_parent"
        android:layout_height="@dimen/bottom_nav_height"
        android:background="@color/bg_surface"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="0dp">

        <TextView
            android:id="@+id/tabMarketMonitor"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:drawablePadding="2dp"
            android:gravity="center"
            android:includeFontPadding="false"
            android:maxLines="1"
            android:paddingTop="6dp"
            android:paddingBottom="4dp"
            android:text="@string/nav_market_monitor"
            android:textColor="@color/text_secondary"
            android:textSize="10.5sp" />

        <TextView
            android:id="@+id/tabMarketChart"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:drawablePadding="2dp"
            android:gravity="center"
            android:includeFontPadding="false"
            android:maxLines="1"
            android:paddingTop="6dp"
            android:paddingBottom="4dp"
            android:text="@string/nav_market_chart"
            android:textColor="@color/white"
            android:textSize="10.5sp" />

        <TextView
            android:id="@+id/tabAccountPosition"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:drawablePadding="2dp"
            android:gravity="center"
            android:includeFontPadding="false"
            android:maxLines="1"
            android:paddingTop="6dp"
            android:paddingBottom="4dp"
            android:text="@string/nav_account_position"
            android:textColor="@color/text_secondary"
            android:textSize="10.5sp" />

        <TextView
            android:id="@+id/tabAccountStats"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:drawablePadding="2dp"
            android:gravity="center"
            android:includeFontPadding="false"
            android:maxLines="1"
            android:paddingTop="6dp"
            android:paddingBottom="4dp"
            android:text="@string/nav_account_stats"
            android:textColor="@color/text_secondary"
            android:textSize="10.5sp" />

    </LinearLayout>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavigation"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:menu="@menu/menu_bottom_nav" />
</LinearLayout>
