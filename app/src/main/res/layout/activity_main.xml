<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app"
    android:orientation="vertical">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:padding="@dimen/screen_edge_padding">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/section_gap">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/container_padding_compact">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="监控工作台"
                    android:textAppearance="@style/TextAppearance.BinanceMonitor.SectionTitle" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_8"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/status_connection"
                        android:textColor="@color/text_secondary"
                        android:textAppearance="@style/TextAppearance.BinanceMonitor.Meta" />

                    <TextView
                        android:id="@+id/tvConnectionStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/inline_gap"
                        android:background="@drawable/bg_chip_selected"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:paddingLeft="@dimen/space_10"
                        android:paddingTop="@dimen/row_gap_compact"
                        android:paddingRight="@dimen/space_10"
                        android:paddingBottom="@dimen/row_gap_compact"
                        android:text="@string/status_unknown"
                        android:textColor="@color/text_inverse"
                        android:textAppearance="@style/TextAppearance.BinanceMonitor.Meta" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/row_gap"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/status_update"
                        android:textColor="@color/text_secondary"
                        android:textAppearance="@style/TextAppearance.BinanceMonitor.Meta" />

                    <TextView
                        android:id="@+id/tvLastUpdate"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/inline_gap"
                        android:text="@string/last_update_placeholder"
                        android:textColor="@color/text_primary"
                        android:textAppearance="@style/TextAppearance.BinanceMonitor.Meta" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_12"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/btnOpenBinance"
                        android:layout_width="0dp"
                        android:layout_height="@dimen/control_height_md"
                        android:layout_weight="1"
                        android:background="@drawable/bg_inline_button"
                        android:gravity="center"
                        android:includeFontPadding="true"
                        android:maxLines="1"
                        android:minHeight="0dp"
                        android:paddingTop="0dp"
                        android:paddingBottom="0dp"
                        android:text="@string/open_binance"
                        android:textAllCaps="false"
                        android:textColor="@color/bg_primary"
                        android:textAppearance="@style/TextAppearance.BinanceMonitor.Body" />

                    <Button
                        android:id="@+id/btnOpenMt5"
                        android:layout_width="0dp"
                        android:layout_height="@dimen/control_height_md"
                        android:layout_marginStart="@dimen/inline_gap"
                        android:layout_weight="1"
                        android:background="@drawable/bg_inline_button"
                        android:gravity="center"
                        android:includeFontPadding="true"
                        android:maxLines="1"
                        android:minHeight="0dp"
                        android:paddingTop="0dp"
                        android:paddingBottom="0dp"
                        android:text="@string/open_mt5"
                        android:textAllCaps="false"
                        android:textColor="@color/bg_primary"
                        android:textAppearance="@style/TextAppearance.BinanceMonitor.Body" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/section_gap">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/container_padding_compact">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/market_card_title"
                    android:textAppearance="@style/TextAppearance.BinanceMonitor.SectionTitle" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_12"
                    android:orientation="horizontal">

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/control_height_md">

                        <androidx.appcompat.widget.AppCompatSpinner
                            android:id="@+id/spinnerSymbolPicker"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@drawable/bg_spinner_filter"
                            android:minWidth="0dp"
                            android:popupBackground="@drawable/bg_spinner_popup"
                            android:spinnerMode="dropdown" />

                        <TextView
                            android:id="@+id/tvMainSymbolPickerLabel"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:clickable="true"
                            android:ellipsize="end"
                            android:focusable="true"
                            android:gravity="center_vertical|start"
                            android:includeFontPadding="false"
                            android:maxLines="1"
                            android:paddingStart="@dimen/space_12"
                            android:paddingEnd="@dimen/field_trailing_reserve"
                            android:textColor="@color/text_primary"
                            android:textAppearance="@style/TextAppearance.BinanceMonitor.Body" />
                    </FrameLayout>
                </LinearLayout>

                <TextView
                    android:id="@+id/tvCurrentPrice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_14"
                    android:maxLines="1"
                    android:text="--"
                    android:textColor="@color/text_primary"
                    android:textAppearance="@style/TextAppearance.BinanceMonitor.PageTitle" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/inline_gap_compact"
                    android:text="@string/latest_closed_kline"
                    android:textColor="@color/text_secondary"
                    android:textAppearance="@style/TextAppearance.BinanceMonitor.Meta" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_12"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <include
                            android:id="@+id/layoutMetricOpen"
                            layout="@layout/item_metric" />

                        <include
                            android:id="@+id/layoutMetricClose"
                            layout="@layout/item_metric" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/row_gap"
                        android:orientation="horizontal">

                        <include
                            android:id="@+id/layoutMetricChange"
                            layout="@layout/item_metric" />

                        <include
                            android:id="@+id/layoutMetricPercent"
                            layout="@layout/item_metric" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/section_gap">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/container_padding_compact">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/recent_records"
                        android:textAppearance="@style/TextAppearance.BinanceMonitor.SectionTitle" />

                    <Button
                        android:id="@+id/btnViewAllRecords"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:minWidth="0dp"
                        android:text="详细记录"
                        android:textAllCaps="false"
                        android:textAppearance="@style/TextAppearance.BinanceMonitor.Tiny" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvRecordsHint"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/row_gap_compact"
                    android:text="@string/records_limit_hint"
                    android:textColor="@color/text_secondary"
                    android:textAppearance="@style/TextAppearance.BinanceMonitor.Meta" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recyclerRecords"
                    android:layout_width="match_parent"
                    android:layout_height="160dp"
                    android:layout_marginTop="@dimen/row_gap"
                    android:fadeScrollbars="false"
                    android:scrollbarStyle="outsideOverlay"
                    android:scrollbars="vertical" />

                <TextView
                    android:id="@+id/tvRecordsEmpty"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="@string/no_records"
                    android:textColor="@color/text_secondary"
                    android:textAppearance="@style/TextAppearance.BinanceMonitor.Control"
                    android:visibility="gone" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/section_gap">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/container_padding_compact">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/threshold_card_title"
                    android:textAppearance="@style/TextAppearance.BinanceMonitor.SectionTitle" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_10"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/inputLayoutVolumeThreshold"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:hint="@string/volume_threshold_hint">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etVolumeThreshold"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="numberDecimal"
                            android:maxLines="1"
                            android:textColor="@color/text_primary"
                            android:textAppearance="@style/TextAppearance.BinanceMonitor.Control" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <TextView
                        android:id="@+id/tvVolumeUnit"
                        android:layout_width="44dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/inline_gap"
                        android:gravity="start|center_vertical"
                        android:text="@string/unit_btc"
                        android:textColor="@color/text_secondary"
                        android:textAppearance="@style/TextAppearance.BinanceMonitor.Meta" />

                    <androidx.appcompat.widget.AppCompatCheckBox
                        android:id="@+id/switchVolume"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/inline_gap"
                        android:minHeight="0dp"
                        android:text="@string/enable_short"
                        android:textColor="@color/text_primary"
                        android:textAppearance="@style/TextAppearance.BinanceMonitor.Meta" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/row_gap"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/inputLayoutAmountThreshold"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:hint="@string/amount_threshold_hint">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etAmountThreshold"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="numberDecimal"
                            android:maxLines="1"
                            android:textColor="@color/text_primary"
                            android:textAppearance="@style/TextAppearance.BinanceMonitor.Control" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <TextView
                        android:id="@+id/tvAmountUnit"
                        android:layout_width="44dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/inline_gap"
                        android:gravity="start|center_vertical"
                        android:text="@string/unit_musd"
                        android:textColor="@color/text_secondary"
                        android:textAppearance="@style/TextAppearance.BinanceMonitor.Meta" />

                    <androidx.appcompat.widget.AppCompatCheckBox
                        android:id="@+id/switchAmount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/inline_gap"
                        android:minHeight="0dp"
                        android:text="@string/enable_short"
                        android:textColor="@color/text_primary"
                        android:textAppearance="@style/TextAppearance.BinanceMonitor.Meta" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/row_gap"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/inputLayoutPriceThreshold"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:hint="@string/price_threshold_hint">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etPriceChangeThreshold"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="numberDecimal"
                            android:maxLines="1"
                            android:textColor="@color/text_primary"
                            android:textAppearance="@style/TextAppearance.BinanceMonitor.Control" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <TextView
                        android:id="@+id/tvPriceUnit"
                        android:layout_width="44dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/inline_gap"
                        android:gravity="start|center_vertical"
                        android:text="@string/unit_usd"
                        android:textColor="@color/text_secondary"
                        android:textAppearance="@style/TextAppearance.BinanceMonitor.Meta" />

                    <androidx.appcompat.widget.AppCompatCheckBox
                        android:id="@+id/switchPriceChange"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/inline_gap"
                        android:minHeight="0dp"
                        android:text="@string/enable_short"
                        android:textColor="@color/text_primary"
                        android:textAppearance="@style/TextAppearance.BinanceMonitor.Meta" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_10"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <RadioGroup
                        android:id="@+id/radioLogicGroup"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="horizontal">

                        <RadioButton
                            android:id="@+id/radioLogicOr"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@null"
                            android:button="@null"
                            android:checked="true"
                            android:minHeight="0dp"
                            android:paddingHorizontal="@dimen/space_8"
                            android:text="@string/logic_or"
                            android:textColor="@color/text_primary"
                            android:textAppearance="@style/TextAppearance.BinanceMonitor.Control" />

                        <RadioButton
                            android:id="@+id/radioLogicAnd"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/inline_gap"
                            android:background="@null"
                            android:button="@null"
                            android:minHeight="0dp"
                            android:paddingHorizontal="@dimen/space_8"
                            android:text="@string/logic_and"
                            android:textColor="@color/text_primary"
                            android:textAppearance="@style/TextAppearance.BinanceMonitor.Control" />
                    </RadioGroup>

                    <Button
                        android:id="@+id/btnRestoreDefault"
                        android:layout_width="132dp"
                        android:layout_height="@dimen/control_height_md"
                        android:background="@drawable/bg_inline_button"
                        android:gravity="center"
                        android:includeFontPadding="true"
                        android:maxLines="1"
                        android:minHeight="0dp"
                        android:paddingTop="0dp"
                        android:paddingBottom="0dp"
                        android:text="@string/restore_default"
                        android:textAllCaps="false"
                        android:textColor="@color/bg_primary"
                        android:textAppearance="@style/TextAppearance.BinanceMonitor.Body" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/section_gap"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/container_padding_compact">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/floating_card_title"
                    android:textAppearance="@style/TextAppearance.BinanceMonitor.SectionTitle" />

                <androidx.appcompat.widget.AppCompatCheckBox
                    android:id="@+id/switchFloatingEnabled"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_10"
                    android:minHeight="0dp"
                    android:text="@string/floating_window"
                    android:textColor="@color/text_primary"
                    android:textAppearance="@style/TextAppearance.BinanceMonitor.Control" />

                <TextView
                    android:id="@+id/tvAlphaValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/row_gap"
                    android:text="88%"
                    android:textColor="@color/text_secondary"
                    android:textAppearance="@style/TextAppearance.BinanceMonitor.Meta" />

                <SeekBar
                    android:id="@+id/seekFloatingAlpha"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:max="100"
                    android:progress="88" />

                <androidx.appcompat.widget.AppCompatCheckBox
                    android:id="@+id/switchShowBtc"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="0dp"
                    android:text="@string/show_btc"
                    android:textColor="@color/text_primary"
                    android:textAppearance="@style/TextAppearance.BinanceMonitor.Control" />

                <androidx.appcompat.widget.AppCompatCheckBox
                    android:id="@+id/switchShowXau"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="0dp"
                    android:text="@string/show_xau"
                    android:textColor="@color/text_primary"
                    android:textAppearance="@style/TextAppearance.BinanceMonitor.Control" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <Button
            android:id="@+id/btnViewLogs"
            android:layout_width="match_parent"
            android:layout_height="@dimen/control_height_md"
            android:layout_marginTop="@dimen/section_gap"
            android:layout_marginBottom="@dimen/space_20"
            android:background="@drawable/bg_inline_button"
            android:gravity="center"
            android:includeFontPadding="true"
            android:maxLines="1"
            android:minHeight="0dp"
            android:paddingTop="0dp"
            android:paddingBottom="0dp"
            android:text="@string/view_logs"
            android:textAllCaps="false"
            android:textColor="@color/bg_primary"
            android:textAppearance="@style/TextAppearance.BinanceMonitor.Body"
            android:visibility="gone" />
    </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <LinearLayout
        android:id="@+id/tabBar"
        android:layout_width="match_parent"
        android:layout_height="@dimen/bottom_nav_height"
        android:background="@android:color/transparent"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="0dp">

        <TextView
            android:id="@+id/tabMarketMonitor"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:drawablePadding="@dimen/inline_gap_compact"
            android:gravity="center"
            android:includeFontPadding="false"
            android:maxLines="1"
            android:paddingTop="@dimen/row_gap"
            android:paddingBottom="@dimen/row_gap_compact"
            android:text="@string/nav_market_monitor"
            android:textColor="@color/text_inverse"
            android:textAppearance="@style/TextAppearance.BinanceMonitor.Tiny" />

        <TextView
            android:id="@+id/tabMarketChart"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:drawablePadding="@dimen/inline_gap_compact"
            android:gravity="center"
            android:includeFontPadding="false"
            android:maxLines="1"
            android:paddingTop="@dimen/row_gap"
            android:paddingBottom="@dimen/row_gap_compact"
            android:text="@string/nav_market_chart"
            android:textColor="@color/text_secondary"
            android:textAppearance="@style/TextAppearance.BinanceMonitor.Tiny" />

        <TextView
            android:id="@+id/tabAccountPosition"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:drawablePadding="@dimen/inline_gap_compact"
            android:gravity="center"
            android:includeFontPadding="false"
            android:maxLines="1"
            android:paddingTop="@dimen/row_gap"
            android:paddingBottom="@dimen/row_gap_compact"
            android:text="@string/nav_account_position"
            android:textColor="@color/text_secondary"
            android:textAppearance="@style/TextAppearance.BinanceMonitor.Tiny" />

        <TextView
            android:id="@+id/tabAccountStats"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:drawablePadding="@dimen/inline_gap_compact"
            android:gravity="center"
            android:includeFontPadding="false"
            android:maxLines="1"
            android:paddingTop="@dimen/row_gap"
            android:paddingBottom="@dimen/row_gap_compact"
            android:text="@string/nav_account_stats"
            android:textColor="@color/text_secondary"
            android:textAppearance="@style/TextAppearance.BinanceMonitor.Tiny" />

    </LinearLayout>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavigation"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:menu="@menu/menu_bottom_nav" />
</LinearLayout>


