<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:gravity="center_vertical"
        android:paddingHorizontal="@dimen/page_horizontal_padding">

        <TextView
            android:id="@+id/btnBack"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:gravity="center"
            android:text="←"
            android:textColor="@color/text_primary"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/tvSettingsDetailTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="设置"
            android:textAppearance="@style/TextAppearance.BinanceMonitor.SectionTitle" />
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:padding="@dimen/page_horizontal_padding">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/cardFloatingSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingVertical="@dimen/space_10">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="悬浮窗与显示"
                    android:textAppearance="@style/TextAppearance.BinanceMonitor.SectionTitle" />

                <androidx.appcompat.widget.AppCompatCheckBox
                    android:id="@+id/switchFloatingEnabled"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_12"
                    android:minHeight="0dp"
                    android:text="@string/floating_window"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/tvAlphaValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_12"
                    android:text="88%"
                    android:textAppearance="@style/TextAppearance.BinanceMonitor.Caption" />

                <SeekBar
                    android:id="@+id/seekFloatingAlpha"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:max="100"
                    android:progress="88" />

                <androidx.appcompat.widget.AppCompatCheckBox
                    android:id="@+id/switchShowBtc"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_12"
                    android:minHeight="0dp"
                    android:text="@string/show_btc"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp" />

                <androidx.appcompat.widget.AppCompatCheckBox
                    android:id="@+id/switchShowXau"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="0dp"
                    android:text="@string/show_xau"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/cardGatewaySection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingVertical="@dimen/space_10">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/mt5_gateway_section_title"
                    android:textAppearance="@style/TextAppearance.BinanceMonitor.SectionTitle" />

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/inputLayoutMt5GatewayUrl"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_8">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etMt5GatewayUrl"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textUri"
                        android:maxLines="1"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp" />
                </com.google.android.material.textfield.TextInputLayout>

                <Button
                    android:id="@+id/btnSaveMt5GatewayUrl"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/control_height_md"
                    android:layout_marginTop="@dimen/space_12"
                    android:background="@android:color/transparent"
                    android:text="@string/mt5_gateway_save"
                    android:textAllCaps="false" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/cardThemeSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingVertical="@dimen/space_10">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="主题设置"
                    android:textAppearance="@style/TextAppearance.BinanceMonitor.SectionTitle" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_8"
                    android:text="点击主题卡片即可即时切换，全局页面和图表会同步跟随。"
                    android:textAppearance="@style/TextAppearance.BinanceMonitor.Caption" />

                <LinearLayout
                    android:id="@+id/cardThemeFinancial"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_12"
                    android:orientation="horizontal"
                    android:padding="@dimen/space_12"
                    android:foreground="?attr/selectableItemBackgroundBorderless">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvThemeFinancialTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="金融专业风"
                            android:textColor="@color/text_primary"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/tvThemeFinancialDesc"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="深色交易屏，绿涨红跌。"
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="72dp"
                        android:layout_height="28dp"
                        android:gravity="center"
                        android:orientation="horizontal">

                        <View
                            android:id="@+id/viewThemeFinancialA"
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:background="@android:color/transparent" />

                        <View
                            android:id="@+id/viewThemeFinancialB"
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:layout_marginStart="6dp"
                            android:background="@android:color/transparent" />

                        <View
                            android:id="@+id/viewThemeFinancialC"
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:layout_marginStart="6dp"
                            android:background="@android:color/transparent" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/cardThemeVintage"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_8"
                    android:orientation="horizontal"
                    android:padding="@dimen/space_12"
                    android:foreground="?attr/selectableItemBackgroundBorderless">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvThemeVintageTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="复古风"
                            android:textColor="@color/text_primary"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/tvThemeVintageDesc"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="纸感底色，暖棕报表感。"
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="72dp"
                        android:layout_height="28dp"
                        android:gravity="center"
                        android:orientation="horizontal">

                        <View
                            android:id="@+id/viewThemeVintageA"
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:background="@android:color/transparent" />

                        <View
                            android:id="@+id/viewThemeVintageB"
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:layout_marginStart="6dp"
                            android:background="@android:color/transparent" />

                        <View
                            android:id="@+id/viewThemeVintageC"
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:layout_marginStart="6dp"
                            android:background="@android:color/transparent" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/cardThemeBinance"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_8"
                    android:orientation="horizontal"
                    android:padding="@dimen/space_12"
                    android:foreground="?attr/selectableItemBackgroundBorderless">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvThemeBinanceTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="币安风格"
                            android:textColor="@color/text_primary"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/tvThemeBinanceDesc"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="保留熟悉感，整体更利落。"
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="72dp"
                        android:layout_height="28dp"
                        android:gravity="center"
                        android:orientation="horizontal">

                        <View
                            android:id="@+id/viewThemeBinanceA"
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:background="@android:color/transparent" />

                        <View
                            android:id="@+id/viewThemeBinanceB"
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:layout_marginStart="6dp"
                            android:background="@android:color/transparent" />

                        <View
                            android:id="@+id/viewThemeBinanceC"
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:layout_marginStart="6dp"
                            android:background="@android:color/transparent" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/cardThemeTradingView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_8"
                    android:orientation="horizontal"
                    android:padding="@dimen/space_12"
                    android:foreground="?attr/selectableItemBackgroundBorderless">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvThemeTradingViewTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="TradingView 风格"
                            android:textColor="@color/text_primary"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/tvThemeTradingViewDesc"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="黑灰冷调，极简专业感。"
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="72dp"
                        android:layout_height="28dp"
                        android:gravity="center"
                        android:orientation="horizontal">

                        <View
                            android:id="@+id/viewThemeTradingViewA"
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:background="@android:color/transparent" />

                        <View
                            android:id="@+id/viewThemeTradingViewB"
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:layout_marginStart="6dp"
                            android:background="@android:color/transparent" />

                        <View
                            android:id="@+id/viewThemeTradingViewC"
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:layout_marginStart="6dp"
                            android:background="@android:color/transparent" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/cardThemeLight"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_8"
                    android:orientation="horizontal"
                    android:padding="@dimen/space_12"
                    android:foreground="?attr/selectableItemBackgroundBorderless">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvThemeLightTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="浅色风格"
                            android:textColor="@color/text_primary"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/tvThemeLightDesc"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="明亮留白，浅色简洁感。"
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="72dp"
                        android:layout_height="28dp"
                        android:gravity="center"
                        android:orientation="horizontal">

                        <View
                            android:id="@+id/viewThemeLightA"
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:background="@android:color/transparent" />

                        <View
                            android:id="@+id/viewThemeLightB"
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:layout_marginStart="6dp"
                            android:background="@android:color/transparent" />

                        <View
                            android:id="@+id/viewThemeLightC"
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:layout_marginStart="6dp"
                            android:background="@android:color/transparent" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/cardTabSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingVertical="@dimen/space_10">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tab 页管理"
                    android:textAppearance="@style/TextAppearance.BinanceMonitor.SectionTitle" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_8"
                    android:text="可隐藏底部导航中的页签（至少保留一个业务页签）。"
                    android:textAppearance="@style/TextAppearance.BinanceMonitor.Caption" />

                <androidx.appcompat.widget.AppCompatCheckBox
                    android:id="@+id/switchTabMarketMonitor"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_12"
                    android:minHeight="0dp"
                    android:text="@string/nav_market_monitor"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp" />

                <androidx.appcompat.widget.AppCompatCheckBox
                    android:id="@+id/switchTabMarketChart"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="0dp"
                    android:text="@string/nav_market_chart"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp" />

                <androidx.appcompat.widget.AppCompatCheckBox
                    android:id="@+id/switchTabAccountStats"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="0dp"
                    android:text="@string/nav_account_stats"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp" />

                <androidx.appcompat.widget.AppCompatCheckBox
                    android:id="@+id/switchTabAccountPosition"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="0dp"
                    android:text="@string/nav_account_position"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/cardCacheSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingVertical="@dimen/space_10">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="缓存管理"
                    android:textAppearance="@style/TextAppearance.BinanceMonitor.SectionTitle" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_8"
                    android:text="支持分别清理历史行情、历史交易和运行时缓存。"
                    android:textAppearance="@style/TextAppearance.BinanceMonitor.Caption" />

                <Button
                    android:id="@+id/btnClearCache"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/control_height_md"
                    android:layout_marginTop="@dimen/space_12"
                    android:background="@android:color/transparent"
                    android:gravity="center"
                    android:maxLines="1"
                    android:minHeight="0dp"
                    android:text="清理缓存数据"
                    android:textAllCaps="false"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp" />
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <LinearLayout
        android:id="@+id/tabBar"
        android:layout_width="match_parent"
        android:layout_height="@dimen/bottom_nav_height"
        android:background="@android:color/transparent"
        android:orientation="horizontal"
        android:padding="0dp">

        <TextView
            android:id="@+id/tabMarketMonitor"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:gravity="center"
            android:text="@string/nav_market_monitor"
            android:textColor="@color/text_secondary"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/tabMarketChart"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:gravity="center"
            android:text="@string/nav_market_chart"
            android:textColor="@color/text_secondary"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/tabAccountPosition"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:gravity="center"
            android:text="@string/nav_account_position"
            android:textColor="@color/text_secondary"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/tabAccountStats"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:gravity="center"
            android:text="@string/nav_account_stats"
            android:textColor="@color/text_secondary"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/tabSettings"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:gravity="center"
            android:text="@string/nav_settings"
            android:textColor="@color/white"
            android:textSize="13sp" />
    </LinearLayout>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavigation"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:menu="@menu/menu_bottom_nav" />
</LinearLayout>
