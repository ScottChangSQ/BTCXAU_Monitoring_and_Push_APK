<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:gravity="center_vertical"
        android:paddingHorizontal="@dimen/screen_edge_padding">

        <TextView
            android:id="@+id/btnBack"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:gravity="center"
            android:text="←"
            android:textAppearance="@style/TextAppearance.BinanceMonitor.Value" />

        <TextView
            android:id="@+id/tvSettingsDetailTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="设置"
            android:textAppearance="@style/TextAppearance.BinanceMonitor.SectionTitle" />
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:padding="@dimen/screen_edge_padding">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/cardFloatingSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingVertical="@dimen/space_10">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="悬浮窗与显示"
                    android:textAppearance="@style/TextAppearance.BinanceMonitor.SectionTitle" />

                <androidx.appcompat.widget.AppCompatCheckBox
                    android:id="@+id/switchFloatingEnabled"
                    style="@style/Widget.BinanceMonitor.Subject.ToggleChoice"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_12"
                    android:text="@string/floating_window" />

                <TextView
                    android:id="@+id/tvAlphaValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_12"
                    android:text="88%"
                    android:textAppearance="@style/TextAppearance.BinanceMonitor.Caption" />

                <SeekBar
                    android:id="@+id/seekFloatingAlpha"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:max="100"
                    android:progress="88" />

                <androidx.appcompat.widget.AppCompatCheckBox
                    android:id="@+id/switchShowBtc"
                    style="@style/Widget.BinanceMonitor.Subject.ToggleChoice"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_12"
                    android:text="@string/show_btc" />

                <androidx.appcompat.widget.AppCompatCheckBox
                    android:id="@+id/switchShowXau"
                    style="@style/Widget.BinanceMonitor.Subject.ToggleChoice"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/show_xau" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/cardGatewaySection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingVertical="@dimen/space_10">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/mt5_gateway_section_title"
                    android:textAppearance="@style/TextAppearance.BinanceMonitor.SectionTitle" />

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/inputLayoutMt5GatewayUrl"
                    style="@style/Widget.BinanceMonitor.Subject.InputField"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_8">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etMt5GatewayUrl"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textUri"
                        android:maxLines="1"
                        android:textAppearance="@style/TextAppearance.BinanceMonitor.BodyCompact" />
                </com.google.android.material.textfield.TextInputLayout>

                <Button
                    android:id="@+id/btnSaveMt5GatewayUrl"
                    style="@style/Widget.BinanceMonitor.Subject.ActionButton.Primary"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/control_height_md"
                    android:layout_marginTop="@dimen/space_12"
                    android:text="@string/mt5_gateway_save" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/cardTradeSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingVertical="@dimen/space_10">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_trade_section"
                    android:textAppearance="@style/TextAppearance.BinanceMonitor.SectionTitle" />

                <TextView
                    android:id="@+id/tvTradeSectionSummary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_8"
                    android:text="@string/settings_trade_section_summary"
                    android:textAppearance="@style/TextAppearance.BinanceMonitor.Caption" />

                <TextView
                    android:id="@+id/tvTradeDefaultTemplate"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_12"
                    android:textAppearance="@style/TextAppearance.BinanceMonitor.BodyCompact" />

                <TextView
                    android:id="@+id/tvTradeTemplateManageSummary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_8"
                    android:textAppearance="@style/TextAppearance.BinanceMonitor.Caption" />

                <Button
                    android:id="@+id/btnManageTradeTemplates"
                    style="@style/Widget.BinanceMonitor.Subject.ActionButton.Secondary"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/control_height_md"
                    android:layout_marginTop="@dimen/space_8"
                    android:text="@string/settings_trade_template_manage_action" />

                <Button
                    android:id="@+id/btnSelectDefaultTradeTemplate"
                    style="@style/Widget.BinanceMonitor.Subject.ActionButton.Secondary"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/control_height_md"
                    android:layout_marginTop="@dimen/space_8"
                    android:text="@string/settings_trade_default_template_action" />

                <TextView
                    android:id="@+id/tvTradeQuickTemplate"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_12"
                    android:textAppearance="@style/TextAppearance.BinanceMonitor.BodyCompact" />

                <Button
                    android:id="@+id/btnSelectQuickTradeTemplate"
                    style="@style/Widget.BinanceMonitor.Subject.ActionButton.Secondary"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/control_height_md"
                    android:layout_marginTop="@dimen/space_8"
                    android:text="@string/settings_trade_quick_template_action" />

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/inputLayoutTradeDefaultVolume"
                    style="@style/Widget.BinanceMonitor.Subject.InputField"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_12"
                    android:hint="@string/settings_trade_default_volume">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etTradeDefaultVolume"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="numberDecimal"
                        android:maxLines="1"
                        android:textAppearance="@style/TextAppearance.BinanceMonitor.BodyCompact" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/inputLayoutTradeDefaultSl"
                    style="@style/Widget.BinanceMonitor.Subject.InputField"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_8"
                    android:hint="@string/settings_trade_default_sl">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etTradeDefaultSl"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="numberDecimal"
                        android:maxLines="1"
                        android:textAppearance="@style/TextAppearance.BinanceMonitor.BodyCompact" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/inputLayoutTradeDefaultTp"
                    style="@style/Widget.BinanceMonitor.Subject.InputField"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_8"
                    android:hint="@string/settings_trade_default_tp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etTradeDefaultTp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="numberDecimal"
                        android:maxLines="1"
                        android:textAppearance="@style/TextAppearance.BinanceMonitor.BodyCompact" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/inputLayoutTradeMaxQuickVolume"
                    style="@style/Widget.BinanceMonitor.Subject.InputField"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_12"
                    android:hint="@string/settings_trade_max_quick_volume">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etTradeMaxQuickVolume"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="numberDecimal"
                        android:maxLines="1"
                        android:textAppearance="@style/TextAppearance.BinanceMonitor.BodyCompact" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/inputLayoutTradeMaxSingleVolume"
                    style="@style/Widget.BinanceMonitor.Subject.InputField"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_8"
                    android:hint="@string/settings_trade_max_single_volume">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etTradeMaxSingleVolume"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="numberDecimal"
                        android:maxLines="1"
                        android:textAppearance="@style/TextAppearance.BinanceMonitor.BodyCompact" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/inputLayoutTradeMaxBatchItems"
                    style="@style/Widget.BinanceMonitor.Subject.InputField"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_8"
                    android:hint="@string/settings_trade_max_batch_items">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etTradeMaxBatchItems"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="number"
                        android:maxLines="1"
                        android:textAppearance="@style/TextAppearance.BinanceMonitor.BodyCompact" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/inputLayoutTradeMaxBatchTotalVolume"
                    style="@style/Widget.BinanceMonitor.Subject.InputField"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_8"
                    android:hint="@string/settings_trade_max_batch_total_volume">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etTradeMaxBatchTotalVolume"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="numberDecimal"
                        android:maxLines="1"
                        android:textAppearance="@style/TextAppearance.BinanceMonitor.BodyCompact" />
                </com.google.android.material.textfield.TextInputLayout>

                <androidx.appcompat.widget.AppCompatCheckBox
                    android:id="@+id/switchTradeForceConfirmAddPosition"
                    style="@style/Widget.BinanceMonitor.Subject.ToggleChoice"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_12"
                    android:text="@string/settings_trade_force_confirm_add_position" />

                <androidx.appcompat.widget.AppCompatCheckBox
                    android:id="@+id/switchTradeForceConfirmReverse"
                    style="@style/Widget.BinanceMonitor.Subject.ToggleChoice"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_trade_force_confirm_reverse" />

                <Button
                    android:id="@+id/btnSaveTradeSettings"
                    style="@style/Widget.BinanceMonitor.Subject.ActionButton.Primary"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/control_height_md"
                    android:layout_marginTop="@dimen/space_12"
                    android:text="@string/settings_trade_save" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/cardCacheSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingVertical="@dimen/space_10">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="缓存管理"
                    android:textAppearance="@style/TextAppearance.BinanceMonitor.SectionTitle" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_8"
                    android:text="支持分别清理历史行情、历史交易和运行时缓存。"
                    android:textAppearance="@style/TextAppearance.BinanceMonitor.Caption" />

                <Button
                    android:id="@+id/btnClearCache"
                    style="@style/Widget.BinanceMonitor.Subject.ActionButton.Secondary"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/control_height_md"
                    android:layout_marginTop="@dimen/space_12"
                    android:gravity="center"
                    android:maxLines="1"
                    android:text="清理缓存数据" />

                <Button
                    android:id="@+id/btnOpenTradeAudit"
                    style="@style/Widget.BinanceMonitor.Subject.ActionButton.Primary"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/control_height_md"
                    android:layout_marginTop="@dimen/space_12"
                    android:text="@string/settings_trade_audit" />
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavigation"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:menu="@menu/menu_bottom_nav" />
</LinearLayout>
