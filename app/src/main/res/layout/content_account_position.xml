<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollAccountPosition"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:padding="@dimen/page_horizontal_padding">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardOverviewSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_8">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingTop="@dimen/card_content_padding"
                    android:paddingBottom="@dimen/card_content_padding"
                    android:paddingStart="4dp"
                    android:paddingEnd="4dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/tvOverviewTitle"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/account_overview_title"
                            android:textAppearance="@style/TextAppearance.BinanceMonitor.SectionTitle" />

                        <TextView
                            android:id="@+id/tvAccountConnectionStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_chip_unselected"
                            android:clickable="true"
                            android:focusable="true"
                            android:paddingHorizontal="8dp"
                            android:paddingVertical="3dp"
                            android:text="未连接账户"
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp" />

                        <androidx.appcompat.widget.AppCompatImageView
                            android:id="@+id/ivAccountPrivacyToggle"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:layout_marginStart="6dp"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:clickable="true"
                            android:focusable="true"
                            android:padding="6dp"
                            android:tint="@color/text_secondary"
                            app:srcCompat="@drawable/ic_privacy_visible" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvUpdatedAt"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_8"
                        android:text="--"
                        android:textAppearance="@style/TextAppearance.BinanceMonitor.Meta" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/recyclerOverviewMetrics"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_8"
                        android:nestedScrollingEnabled="false" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardPositionSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/page_section_gap">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/card_content_padding">

                    <TextView
                        android:id="@+id/tvPositionSectionTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/current_positions_title"
                        android:textAppearance="@style/TextAppearance.BinanceMonitor.SectionTitle" />

                    <TextView
                        android:id="@+id/tvPositionSummary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_8"
                        android:text="当前持仓 0 条"
                        android:textAppearance="@style/TextAppearance.BinanceMonitor.Meta" />

                    <TextView
                        android:id="@+id/tvPositionAggregateTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_8"
                        android:text="@string/account_position_aggregate_title"
                        android:textAppearance="@style/TextAppearance.BinanceMonitor.Meta" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/recyclerPositionAggregates"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_8"
                        android:nestedScrollingEnabled="false" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/recyclerPositions"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_8"
                        android:nestedScrollingEnabled="false" />

                    <TextView
                        android:id="@+id/tvPositionsEmpty"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_4"
                        android:text="暂无持仓"
                        android:textAppearance="@style/TextAppearance.BinanceMonitor.Meta"
                        android:visibility="gone" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardPendingSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/page_section_gap"
                android:layout_marginBottom="@dimen/space_20">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/card_content_padding">

                    <TextView
                        android:id="@+id/tvPendingSectionTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="挂单"
                        android:textAppearance="@style/TextAppearance.BinanceMonitor.SectionTitle" />

                    <TextView
                        android:id="@+id/tvPendingSummary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_8"
                        android:text="挂单 0 条"
                        android:textAppearance="@style/TextAppearance.BinanceMonitor.Meta" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/recyclerPendingOrders"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_8"
                        android:nestedScrollingEnabled="false" />

                    <TextView
                        android:id="@+id/tvPendingOrdersEmpty"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_4"
                        android:text="暂无挂单"
                        android:textAppearance="@style/TextAppearance.BinanceMonitor.Meta"
                        android:visibility="gone" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</merge>
