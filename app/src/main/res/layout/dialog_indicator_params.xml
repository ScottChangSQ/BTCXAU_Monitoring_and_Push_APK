<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="4dp">

    <TextView
        android:id="@+id/tvParamHint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/text_secondary"
        android:textSize="12sp" />

    <TextView
        android:id="@+id/tvParamLabel1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:textColor="@color/text_primary"
        android:textSize="12sp" />

    <EditText
        android:id="@+id/etParamValue1"
        android:layout_width="match_parent"
        android:layout_height="@dimen/control_height_md"
        android:layout_marginTop="4dp"
        android:background="@drawable/bg_spinner_filter"
        android:gravity="center_vertical"
        android:inputType="number"
        android:paddingHorizontal="12dp"
        android:textColor="@color/text_primary"
        android:textSize="13sp" />

    <TextView
        android:id="@+id/tvParamLabel2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textColor="@color/text_primary"
        android:textSize="12sp"
        android:visibility="gone" />

    <EditText
        android:id="@+id/etParamValue2"
        android:layout_width="match_parent"
        android:layout_height="@dimen/control_height_md"
        android:layout_marginTop="4dp"
        android:background="@drawable/bg_spinner_filter"
        android:gravity="center_vertical"
        android:inputType="number"
        android:paddingHorizontal="12dp"
        android:textColor="@color/text_primary"
        android:textSize="13sp"
        android:visibility="gone" />

    <TextView
        android:id="@+id/tvParamLabel3"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textColor="@color/text_primary"
        android:textSize="12sp"
        android:visibility="gone" />

    <EditText
        android:id="@+id/etParamValue3"
        android:layout_width="match_parent"
        android:layout_height="@dimen/control_height_md"
        android:layout_marginTop="4dp"
        android:background="@drawable/bg_spinner_filter"
        android:gravity="center_vertical"
        android:inputType="number"
        android:paddingHorizontal="12dp"
        android:textColor="@color/text_primary"
        android:textSize="13sp"
        android:visibility="gone" />
</LinearLayout>
