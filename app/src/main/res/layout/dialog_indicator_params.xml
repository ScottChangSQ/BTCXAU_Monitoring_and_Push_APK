<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="@dimen/dialog_content_padding">

    <TextView
        android:id="@+id/tvParamHint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/text_secondary"
        android:textAppearance="@style/TextAppearance.BinanceMonitor.Meta" />

    <TextView
        android:id="@+id/tvParamLabel1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/row_gap"
        android:textColor="@color/text_primary"
        android:textAppearance="@style/TextAppearance.BinanceMonitor.Meta" />

    <EditText
        android:id="@+id/etParamValue1"
        android:layout_width="match_parent"
        android:layout_height="@dimen/subject_height_md"
        android:layout_marginTop="@dimen/row_gap_compact"
        android:gravity="center_vertical"
        android:inputType="number"
        android:singleLine="true" />

    <TextView
        android:id="@+id/tvParamLabel2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/row_gap"
        android:textColor="@color/text_primary"
        android:textAppearance="@style/TextAppearance.BinanceMonitor.Meta"
        android:visibility="gone" />

    <EditText
        android:id="@+id/etParamValue2"
        android:layout_width="match_parent"
        android:layout_height="@dimen/subject_height_md"
        android:layout_marginTop="@dimen/row_gap_compact"
        android:gravity="center_vertical"
        android:inputType="number"
        android:singleLine="true"
        android:visibility="gone" />

    <TextView
        android:id="@+id/tvParamLabel3"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/row_gap"
        android:textColor="@color/text_primary"
        android:textAppearance="@style/TextAppearance.BinanceMonitor.Meta"
        android:visibility="gone" />

    <EditText
        android:id="@+id/etParamValue3"
        android:layout_width="match_parent"
        android:layout_height="@dimen/subject_height_md"
        android:layout_marginTop="@dimen/row_gap_compact"
        android:gravity="center_vertical"
        android:inputType="number"
        android:singleLine="true"
        android:visibility="gone" />
</LinearLayout>
