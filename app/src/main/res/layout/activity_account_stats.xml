<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app"
    android:orientation="vertical">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollAccountStats"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:padding="10dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="10dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/tvAccountOverviewTitle"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:fontFamily="serif"
                            android:text="账户总览（账号）"
                            android:textColor="@color/text_primary"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvAccountConnectionStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_chip_unselected"
                            android:clickable="true"
                            android:focusable="true"
                            android:paddingHorizontal="8dp"
                            android:paddingVertical="3dp"
                            android:text="未连接账户"
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvAccountMeta"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="更新时间 --"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/recyclerOverview"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:nestedScrollingEnabled="false" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardCurveSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="10dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="净值曲线 / 结余曲线"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/tvCurveTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="serif"
                        android:text="净值/结余曲线"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <com.google.android.material.button.MaterialButtonToggleGroup
                        android:id="@+id/toggleTimeRange"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        app:singleSelection="true">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnRange1d"
                            style="?attr/materialButtonOutlinedStyle"
                            android:layout_width="0dp"
                            android:layout_height="32dp"
                            android:layout_weight="1"
                            android:ellipsize="none"
                            android:gravity="center"
                            android:includeFontPadding="false"
                            android:maxLines="1"
                            android:minWidth="0dp"
                            android:paddingHorizontal="0dp"
                            android:text="1D"
                            android:textAllCaps="false"
                            android:textSize="10sp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnRange7d"
                            style="?attr/materialButtonOutlinedStyle"
                            android:layout_width="0dp"
                            android:layout_height="32dp"
                            android:layout_weight="1"
                            android:ellipsize="none"
                            android:gravity="center"
                            android:includeFontPadding="false"
                            android:maxLines="1"
                            android:minWidth="0dp"
                            android:paddingHorizontal="0dp"
                            android:text="7D"
                            android:textAllCaps="false"
                            android:textSize="10sp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnRange1m"
                            style="?attr/materialButtonOutlinedStyle"
                            android:layout_width="0dp"
                            android:layout_height="32dp"
                            android:layout_weight="1"
                            android:ellipsize="none"
                            android:gravity="center"
                            android:includeFontPadding="false"
                            android:maxLines="1"
                            android:minWidth="0dp"
                            android:paddingHorizontal="0dp"
                            android:text="1M"
                            android:textAllCaps="false"
                            android:textSize="10sp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnRange3m"
                            style="?attr/materialButtonOutlinedStyle"
                            android:layout_width="0dp"
                            android:layout_height="32dp"
                            android:layout_weight="1"
                            android:ellipsize="none"
                            android:gravity="center"
                            android:includeFontPadding="false"
                            android:maxLines="1"
                            android:minWidth="0dp"
                            android:paddingHorizontal="0dp"
                            android:text="3M"
                            android:textAllCaps="false"
                            android:textSize="10sp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnRange1y"
                            style="?attr/materialButtonOutlinedStyle"
                            android:layout_width="0dp"
                            android:layout_height="32dp"
                            android:layout_weight="1"
                            android:ellipsize="none"
                            android:gravity="center"
                            android:includeFontPadding="false"
                            android:maxLines="1"
                            android:minWidth="0dp"
                            android:paddingHorizontal="0dp"
                            android:text="1Y"
                            android:textAllCaps="false"
                            android:textSize="10sp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnRangeAll"
                            style="?attr/materialButtonOutlinedStyle"
                            android:layout_width="0dp"
                            android:layout_height="32dp"
                            android:layout_weight="1"
                            android:ellipsize="none"
                            android:gravity="center"
                            android:includeFontPadding="false"
                            android:maxLines="1"
                            android:minWidth="0dp"
                            android:paddingHorizontal="0dp"
                            android:text="ALL"
                            android:textAllCaps="false"
                            android:textSize="10sp" />
                    </com.google.android.material.button.MaterialButtonToggleGroup>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <EditText
                            android:id="@+id/etRangeStart"
                            android:layout_width="0dp"
                            android:layout_height="32dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_inline_button"
                            android:focusable="false"
                            android:gravity="center"
                            android:hint="开始日期"
                            android:maxLines="1"
                            android:textColor="@color/text_primary"
                            android:textColorHint="@color/text_secondary"
                            android:textSize="12sp" />

                        <EditText
                            android:id="@+id/etRangeEnd"
                            android:layout_width="0dp"
                            android:layout_height="32dp"
                            android:layout_marginStart="6dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_inline_button"
                            android:focusable="false"
                            android:gravity="center"
                            android:hint="结束日期"
                            android:maxLines="1"
                            android:textColor="@color/text_primary"
                            android:textColorHint="@color/text_secondary"
                            android:textSize="12sp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnApplyManualRange"
                            android:layout_width="wrap_content"
                            android:layout_height="34dp"
                            android:layout_marginStart="6dp"
                            android:background="@drawable/bg_chip_selected"
                            android:gravity="center"
                            android:includeFontPadding="false"
                            android:minHeight="0dp"
                            android:minWidth="0dp"
                            android:paddingHorizontal="10dp"
                            android:paddingVertical="0dp"
                            android:text="应用"
                            android:textAllCaps="false"
                            android:textColor="@color/bg_primary"
                            android:textSize="12sp"
                            />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/layoutManualDatePickerPanel"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:background="@drawable/bg_chip_unselected"
                        android:orientation="vertical"
                        android:padding="8dp"
                        android:visibility="gone">

                        <TextView
                            android:id="@+id/tvManualDatePickerTitle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:fontFamily="serif"
                            android:text="选择日期"
                            android:textColor="@color/text_primary"
                            android:textSize="12sp"
                            android:textStyle="bold" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:orientation="horizontal">

                            <NumberPicker
                                android:id="@+id/npManualYear"
                                android:layout_width="0dp"
                                android:layout_height="120dp"
                                android:layout_weight="1" />

                            <NumberPicker
                                android:id="@+id/npManualMonth"
                                android:layout_width="0dp"
                                android:layout_height="120dp"
                                android:layout_weight="1" />

                            <NumberPicker
                                android:id="@+id/npManualDay"
                                android:layout_width="0dp"
                                android:layout_height="120dp"
                                android:layout_weight="1" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:orientation="horizontal">

                            <Button
                                android:id="@+id/btnManualDateCancel"
                                android:layout_width="0dp"
                                android:layout_height="32dp"
                                android:layout_weight="1"
                                android:background="@drawable/bg_inline_button"
                                android:text="取消"
                                android:textAllCaps="false"
                                android:textColor="@color/text_primary"
                                android:textSize="12sp" />

                            <Button
                                android:id="@+id/btnManualDateConfirm"
                                android:layout_width="0dp"
                                android:layout_height="32dp"
                                android:layout_marginStart="6dp"
                                android:layout_weight="1"
                                android:background="@drawable/bg_chip_selected"
                                android:text="确定"
                                android:textAllCaps="false"
                                android:textColor="@color/bg_primary"
                                android:textSize="12sp" />
                        </LinearLayout>
                    </LinearLayout>

                    <com.binance.monitor.ui.account.EquityCurveView
                        android:id="@+id/equityCurveView"
                        android:layout_width="match_parent"
                        android:layout_height="220dp"
                        android:layout_marginTop="8dp" />

                    <TextView
                        android:id="@+id/tvCurveMeta"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"
                        android:visibility="gone" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/recyclerCurveIndicators"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:nestedScrollingEnabled="false" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardReturnStatsSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="10dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="serif"
                        android:text="收益统计表"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvMonthlyReturnsTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:fontFamily="serif"
                        android:text="收益率统计"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <com.google.android.material.button.MaterialButtonToggleGroup
                        android:id="@+id/toggleReturnStatsMode"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        app:singleSelection="true">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnReturnDay"
                            style="?attr/materialButtonOutlinedStyle"
                            android:layout_width="0dp"
                            android:layout_height="36dp"
                            android:layout_weight="1"
                            android:ellipsize="none"
                            android:gravity="center"
                            android:maxLines="1"
                            android:minWidth="0dp"
                            android:text="日收益"
                            android:textAllCaps="false"
                            android:textSize="10sp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnReturnMonth"
                            style="?attr/materialButtonOutlinedStyle"
                            android:layout_width="0dp"
                            android:layout_height="36dp"
                            android:layout_weight="1"
                            android:ellipsize="none"
                            android:gravity="center"
                            android:maxLines="1"
                            android:minWidth="0dp"
                            android:text="月收益"
                            android:textAllCaps="false"
                            android:textSize="10sp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnReturnYear"
                            style="?attr/materialButtonOutlinedStyle"
                            android:layout_width="0dp"
                            android:layout_height="36dp"
                            android:layout_weight="1"
                            android:ellipsize="none"
                            android:gravity="center"
                            android:maxLines="1"
                            android:minWidth="0dp"
                            android:text="年收益"
                            android:textAllCaps="false"
                            android:textSize="10sp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnReturnStage"
                            style="?attr/materialButtonOutlinedStyle"
                            android:layout_width="0dp"
                            android:layout_height="36dp"
                            android:layout_weight="1"
                            android:ellipsize="none"
                            android:gravity="center"
                            android:maxLines="1"
                            android:minWidth="0dp"
                            android:text="阶段收益"
                            android:textAllCaps="false"
                            android:textSize="10sp" />
                    </com.google.android.material.button.MaterialButtonToggleGroup>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/tvReturnsPeriod"
                            android:layout_width="0dp"
                            android:layout_height="32dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_inline_button"
                            android:gravity="center_vertical"
                            android:paddingHorizontal="10dp"
                            android:text="统计日期"
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp" />

                        <com.google.android.material.button.MaterialButtonToggleGroup
                            android:id="@+id/toggleReturnsValueMode"
                            android:layout_width="wrap_content"
                            android:layout_height="36dp"
                            android:layout_marginStart="6dp"
                            app:singleSelection="true">

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnReturnsRate"
                                style="?attr/materialButtonOutlinedStyle"
                                android:layout_width="wrap_content"
                                android:layout_height="36dp"
                                android:minWidth="58dp"
                                android:text="收益率"
                                android:textAllCaps="false"
                                android:textSize="10sp" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnReturnsAmount"
                                style="?attr/materialButtonOutlinedStyle"
                                android:layout_width="wrap_content"
                                android:layout_height="36dp"
                                android:minWidth="58dp"
                                android:text="收益额"
                                android:textAllCaps="false"
                                android:textSize="10sp" />
                        </com.google.android.material.button.MaterialButtonToggleGroup>
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/layoutReturnPeriodPickerPanel"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:background="@drawable/bg_chip_unselected"
                        android:orientation="vertical"
                        android:padding="8dp"
                        android:visibility="gone">

                        <TextView
                            android:id="@+id/tvReturnPeriodPickerTitle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:fontFamily="serif"
                            android:text="选择统计年月"
                            android:textColor="@color/text_primary"
                            android:textSize="12sp"
                            android:textStyle="bold" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:orientation="horizontal">

                            <NumberPicker
                                android:id="@+id/npReturnYear"
                                android:layout_width="0dp"
                                android:layout_height="120dp"
                                android:layout_weight="1" />

                            <NumberPicker
                                android:id="@+id/npReturnMonth"
                                android:layout_width="0dp"
                                android:layout_height="120dp"
                                android:layout_weight="1" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:orientation="horizontal">

                            <Button
                                android:id="@+id/btnReturnPeriodCancel"
                                android:layout_width="0dp"
                                android:layout_height="32dp"
                                android:layout_weight="1"
                                android:background="@drawable/bg_inline_button"
                                android:text="取消"
                                android:textAllCaps="false"
                                android:textColor="@color/text_primary"
                                android:textSize="12sp" />

                            <Button
                                android:id="@+id/btnReturnPeriodConfirm"
                                android:layout_width="0dp"
                                android:layout_height="32dp"
                                android:layout_marginStart="6dp"
                                android:layout_weight="1"
                                android:background="@drawable/bg_chip_selected"
                                android:text="确定"
                                android:textAllCaps="false"
                                android:textColor="@color/bg_primary"
                                android:textSize="12sp" />
                        </LinearLayout>
                    </LinearLayout>

                    <TableLayout
                        android:id="@+id/tableMonthlyReturns"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:shrinkColumns="*"
                        android:stretchColumns="*" />

                    <TextView
                        android:id="@+id/tvMonthlyReturnsHint"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="10dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="serif"
                        android:text="当前持仓"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvPositionPnlSummary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:textColor="@color/text_primary"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvPositionAggregateTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:fontFamily="serif"
                        android:text="按产品汇总"
                        android:textColor="@color/text_primary"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/recyclerPositionByProduct"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:nestedScrollingEnabled="false" />

                    <TextView
                        android:id="@+id/tvPositionDetailTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:fontFamily="serif"
                        android:text="持仓明细"
                        android:textColor="@color/text_primary"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <Spinner
                        android:id="@+id/spinnerPositionSort"
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:visibility="gone" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/recyclerPositions"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:nestedScrollingEnabled="false" />

                    <TextView
                        android:id="@+id/tvPendingOrdersTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:fontFamily="serif"
                        android:text="挂单信息"
                        android:textColor="@color/text_primary"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/recyclerPendingOrders"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:nestedScrollingEnabled="false" />

                    <TextView
                        android:id="@+id/tvPositionCostSummary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"
                        android:visibility="gone" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="10dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="serif"
                        android:text="交易记录"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/etTradeSearch"
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:visibility="gone" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:orientation="horizontal">

                        <FrameLayout
                            android:layout_width="0dp"
                            android:layout_height="36dp"
                            android:layout_weight="1.25">

                            <androidx.appcompat.widget.AppCompatSpinner
                                android:id="@+id/spinnerTradeProduct"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@drawable/bg_spinner_filter"
                                android:minWidth="0dp"
                                android:popupBackground="@drawable/bg_spinner_popup"
                                android:spinnerMode="dropdown" />

                            <TextView
                                android:id="@+id/tvTradeProductLabel"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:clickable="false"
                                android:ellipsize="end"
                                android:focusable="false"
                                android:gravity="center_vertical|start"
                                android:includeFontPadding="false"
                                android:maxLines="1"
                                android:paddingStart="10dp"
                                android:paddingEnd="24dp"
                                android:textColor="@color/text_primary"
                                android:textSize="12sp" />
                        </FrameLayout>

                        <FrameLayout
                            android:layout_width="0dp"
                            android:layout_height="36dp"
                            android:layout_marginStart="1dp"
                            android:layout_weight="1.1">

                            <androidx.appcompat.widget.AppCompatSpinner
                                android:id="@+id/spinnerTradeSide"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@drawable/bg_spinner_filter"
                                android:minWidth="0dp"
                                android:popupBackground="@drawable/bg_spinner_popup"
                                android:spinnerMode="dropdown" />

                            <TextView
                                android:id="@+id/tvTradeSideLabel"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:clickable="false"
                                android:ellipsize="end"
                                android:focusable="false"
                                android:gravity="center_vertical|start"
                                android:includeFontPadding="false"
                                android:maxLines="1"
                                android:paddingStart="10dp"
                                android:paddingEnd="24dp"
                                android:textColor="@color/text_primary"
                                android:textSize="12sp" />
                        </FrameLayout>

                        <FrameLayout
                            android:layout_width="0dp"
                            android:layout_height="36dp"
                            android:layout_marginStart="1dp"
                            android:layout_weight="1.25">

                            <androidx.appcompat.widget.AppCompatSpinner
                                android:id="@+id/spinnerTradeSort"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@drawable/bg_spinner_filter"
                                android:minWidth="0dp"
                                android:popupBackground="@drawable/bg_spinner_popup"
                                android:spinnerMode="dropdown" />

                            <TextView
                                android:id="@+id/tvTradeSortLabel"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:clickable="false"
                                android:ellipsize="end"
                                android:focusable="false"
                                android:gravity="center_vertical|start"
                                android:includeFontPadding="false"
                                android:maxLines="1"
                                android:paddingStart="10dp"
                                android:paddingEnd="24dp"
                                android:textColor="@color/text_primary"
                                android:textSize="12sp" />
                        </FrameLayout>
                    </LinearLayout>

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/recyclerTrades"
                        android:layout_width="match_parent"
                        android:layout_height="300dp"
                        android:layout_marginTop="6dp"
                        android:nestedScrollingEnabled="true"
                        android:scrollbars="vertical" />

                    <TextView
                        android:id="@+id/tvTradeRecordsPnlSummary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="交易次数：0次    盈亏：+0$    库存费：+0$    结余：+0$"
                        android:textColor="@color/text_primary"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="10dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="serif"
                        android:text="交易统计"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/recyclerStats"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:nestedScrollingEnabled="false" />

                    <com.google.android.material.button.MaterialButtonToggleGroup
                        android:id="@+id/toggleTradePnlSide"
                        android:layout_width="wrap_content"
                        android:layout_height="34dp"
                        android:layout_marginTop="8dp"
                        app:singleSelection="true">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnTradePnlAll"
                            style="?attr/materialButtonOutlinedStyle"
                            android:layout_width="wrap_content"
                            android:layout_height="34dp"
                            android:minWidth="66dp"
                            android:text="全部"
                            android:textAllCaps="false"
                            android:textSize="11sp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnTradePnlBuy"
                            style="?attr/materialButtonOutlinedStyle"
                            android:layout_width="wrap_content"
                            android:layout_height="34dp"
                            android:minWidth="66dp"
                            android:text="买入"
                            android:textAllCaps="false"
                            android:textSize="11sp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnTradePnlSell"
                            style="?attr/materialButtonOutlinedStyle"
                            android:layout_width="wrap_content"
                            android:layout_height="34dp"
                            android:minWidth="66dp"
                            android:text="卖出"
                            android:textAllCaps="false"
                            android:textSize="11sp" />
                    </com.google.android.material.button.MaterialButtonToggleGroup>

                    <TextView
                        android:id="@+id/tvTradePnlSummary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:textColor="@color/text_primary"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvTradePnlLegend"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp"
                        android:visibility="gone" />

                    <com.binance.monitor.ui.account.TradePnlBarChartView
                        android:id="@+id/tradePnlBarChart"
                        android:layout_width="match_parent"
                        android:layout_height="220dp"
                        android:layout_marginTop="8dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <LinearLayout
        android:id="@+id/tabBar"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@drawable/bg_bottom_nav"
        android:orientation="horizontal"
        android:padding="6dp">

        <TextView
            android:id="@+id/tabMarketMonitor"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@drawable/bg_chip_unselected"
            android:gravity="center"
            android:text="@string/nav_market_monitor"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tabAccountStats"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:background="@drawable/bg_chip_selected"
            android:gravity="center"
            android:text="@string/nav_account_stats"
            android:textColor="@color/bg_primary"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tabSettings"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:background="@drawable/bg_chip_unselected"
            android:gravity="center"
            android:text="设置"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:textStyle="bold" />
    </LinearLayout>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavigation"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:menu="@menu/menu_bottom_nav" />
</LinearLayout>
