<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.BinanceMonitor" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/accent_gold</item>
        <item name="colorOnPrimary">@color/bg_primary</item>
        <item name="colorSecondary">@color/accent_cyan</item>
        <item name="colorOnSecondary">@color/bg_card</item>
        <item name="colorTertiary">@color/accent_red</item>
        <item name="colorSurface">@color/bg_card</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorControlActivated">@color/accent_gold</item>
        <item name="android:statusBarColor">@color/bg_surface</item>
        <item name="android:navigationBarColor">@color/bg_card</item>
        <item name="android:windowBackground">@drawable/bg_app</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="materialCardViewStyle">@style/Widget.BinanceMonitor.Card</item>
        <item name="textInputStyle">@style/Widget.BinanceMonitor.TextInputLayout</item>
        <item name="materialButtonOutlinedStyle">@style/Widget.BinanceMonitor.Button.Outlined</item>
        <item name="materialAlertDialogTheme">@style/ThemeOverlay.BinanceMonitor.AlertDialog</item>
        <item name="android:windowLightStatusBar" tools:targetApi="23">true</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="27">true</item>
    </style>

    <style name="Widget.BinanceMonitor.Card" parent="Widget.Material3.CardView.Filled">
        <item name="cardBackgroundColor">@color/bg_card</item>
        <item name="strokeColor">@color/stroke_card</item>
        <item name="strokeWidth">1dp</item>
        <item name="cardCornerRadius">6dp</item>
        <item name="cardElevation">2dp</item>
    </style>

    <style name="Widget.BinanceMonitor.TextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox.Dense">
        <item name="boxBackgroundColor">@color/bg_input</item>
        <item name="boxCornerRadiusTopStart">6dp</item>
        <item name="boxCornerRadiusTopEnd">6dp</item>
        <item name="boxCornerRadiusBottomStart">6dp</item>
        <item name="boxCornerRadiusBottomEnd">6dp</item>
        <item name="hintTextColor">@color/text_secondary</item>
        <item name="boxStrokeColor">@color/stroke_card</item>
    </style>

    <style name="Widget.BinanceMonitor.Button.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:textColor">@color/text_primary</item>
        <item name="strokeColor">@color/stroke_card</item>
        <item name="strokeWidth">1dp</item>
        <item name="backgroundTint">@color/bg_input</item>
        <item name="cornerRadius">4dp</item>
    </style>

    <style name="TextAppearance.BinanceMonitor.Title" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:fontFamily">serif</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="TextAppearance.BinanceMonitor.Body" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="ThemeOverlay.BinanceMonitor.AlertDialog" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="backgroundTint">@color/bg_card</item>
        <item name="colorSurface">@color/bg_card</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="colorPrimary">@color/accent_gold</item>
        <item name="colorOnPrimary">@color/bg_primary</item>
    </style>
</resources>
