    <style name="TextAppearance.BinanceMonitor.Scale.Body" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">14sp</item>
        <item name="android:lineHeight">20sp</item>
    </style>

    <style name="TextAppearance.BinanceMonitor.Scale.Compact" parent="TextAppearance.Material3.BodySmall">
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">12sp</item>
        <item name="android:lineHeight">16sp</item>
    </style>

    <style name="TextAppearance.BinanceMonitor.Scale.Dense" parent="TextAppearance.Material3.BodySmall">
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">10sp</item>
        <item name="android:lineHeight">14sp</item>
    </style>

    <style name="TextAppearance.BinanceMonitor.PageTitle" parent="TextAppearance.BinanceMonitor.Scale.PageHero" />

    <style name="TextAppearance.BinanceMonitor.SectionTitle" parent="TextAppearance.BinanceMonitor.Scale.Section" />

    <style name="TextAppearance.BinanceMonitor.SectionLabel" parent="TextAppearance.BinanceMonitor.Scale.Body" />

    <style name="TextAppearance.BinanceMonitor.Caption" parent="TextAppearance.BinanceMonitor.Scale.Compact" />

    <style name="TextAppearance.BinanceMonitor.Body" parent="TextAppearance.BinanceMonitor.Scale.Body" />

    <style name="TextAppearance.BinanceMonitor.BodyStrong" parent="TextAppearance.BinanceMonitor.Scale.Body">
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="TextAppearance.BinanceMonitor.BodyCompact" parent="TextAppearance.BinanceMonitor.Body">
    </style>

    <style name="TextAppearance.BinanceMonitor.BodyCompactSecondary" parent="TextAppearance.BinanceMonitor.BodyCompact">
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <style name="TextAppearance.BinanceMonitor.Meta" parent="TextAppearance.BinanceMonitor.Scale.Compact">
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <style name="TextAppearance.BinanceMonitor.MetaStrong" parent="TextAppearance.BinanceMonitor.Scale.Compact">
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <style name="TextAppearance.BinanceMonitor.MetaStrongSingleLine" parent="TextAppearance.BinanceMonitor.MetaStrong">
        <item name="android:includeFontPadding">false</item>
        <item name="android:lineHeight">14sp</item>
        <item name="lineHeight">14sp</item>
    </style>

    <style name="TextAppearance.BinanceMonitor.Micro" parent="TextAppearance.BinanceMonitor.Scale.Dense">
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <style name="TextAppearance.BinanceMonitor.MicroStrong" parent="TextAppearance.BinanceMonitor.Micro">
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="TextAppearance.BinanceMonitor.Tiny" parent="TextAppearance.BinanceMonitor.Scale.Dense">
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <style name="TextAppearance.BinanceMonitor.TinyStrong" parent="TextAppearance.BinanceMonitor.Tiny">
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="TextAppearance.BinanceMonitor.Value" parent="TextAppearance.BinanceMonitor.Scale.ValueHero">
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="TextAppearance.BinanceMonitor.ValueCompact" parent="TextAppearance.BinanceMonitor.Scale.Compact">
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="TextAppearance.BinanceMonitor.Control" parent="TextAppearance.BinanceMonitor.Scale.Compact">
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="TextAppearance.BinanceMonitor.ControlCompact" parent="TextAppearance.BinanceMonitor.Control">
    </style>

    <style name="TextAppearance.BinanceMonitor.ChartCompact" parent="TextAppearance.BinanceMonitor.Scale.Compact" />

    <style name="TextAppearance.BinanceMonitor.ChartDense" parent="TextAppearance.BinanceMonitor.Scale.Dense" />

    <style name="TextAppearance.BinanceMonitor.OverlayDense" parent="TextAppearance.BinanceMonitor.Scale.Dense" />

    <!-- ActionButton 与 TextTrigger 因控件父类不同保留骨架，统一真值仍是 subject_* token。 -->
    <style name="Widget.BinanceMonitor.Subject.ActionButton.Base" parent="Widget.Material3.Button">
        <item name="cornerRadius">0dp</item>
        <item name="android:minHeight">@dimen/subject_height_md</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:gravity">center</item>
        <item name="android:textAlignment">center</item>
        <item name="android:includeFontPadding">false</item>
        <item name="android:maxLines">1</item>
        <item name="android:singleLine">true</item>
        <item name="android:ellipsize">end</item>
        <item name="android:textAppearance">@style/TextAppearance.BinanceMonitor.Control</item>
        <item name="android:paddingStart">@dimen/field_padding_x</item>
        <item name="android:paddingEnd">@dimen/field_padding_x</item>
        <item name="android:paddingTop">0dp</item>
        <item name="android:paddingBottom">0dp</item>
    </style>

    <style name="Widget.BinanceMonitor.Subject.ActionButton.Primary" parent="Widget.BinanceMonitor.Subject.ActionButton.Base">
        <item name="backgroundTint">@color/accent_primary</item>
        <item name="android:textColor">@color/text_inverse</item>
    </style>

    <style name="Widget.BinanceMonitor.Subject.ActionButton.Secondary" parent="Widget.BinanceMonitor.Subject.ActionButton.Base">
        <item name="android:textColor">@color/text_primary</item>
        <item name="strokeColor">@android:color/transparent</item>
        <item name="strokeWidth">0dp</item>
        <item name="backgroundTint">@color/bg_field_base</item>
        <item name="cornerRadius">0dp</item>
    </style>

    <style name="Widget.BinanceMonitor.Subject.TextTrigger" parent="">
        <item name="android:minWidth">0dp</item>
        <item name="android:minHeight">@dimen/subject_height_md</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:gravity">center</item>
        <item name="android:textAlignment">center</item>
        <item name="android:includeFontPadding">false</item>
        <item name="android:maxLines">1</item>
        <item name="android:singleLine">true</item>
        <item name="android:ellipsize">end</item>
        <item name="android:textAppearance">@style/TextAppearance.BinanceMonitor.Control</item>
        <item name="android:paddingStart">@dimen/field_padding_x</item>
        <item name="android:paddingEnd">@dimen/field_padding_x</item>
        <item name="android:paddingTop">0dp</item>
        <item name="android:paddingBottom">0dp</item>
    </style>

    <style name="Widget.BinanceMonitor.Subject.TextTrigger.Compact" parent="Widget.BinanceMonitor.Subject.TextTrigger">
        <item name="android:minHeight">@dimen/subject_height_compact</item>
        <item name="android:textAppearance">@style/TextAppearance.BinanceMonitor.ControlCompact</item>
        <item name="android:paddingStart">@dimen/field_padding_x_compact</item>
        <item name="android:paddingEnd">@dimen/field_padding_x_compact</item>
    </style>

    <style name="Widget.BinanceMonitor.Subject.SegmentedOption" parent="Widget.BinanceMonitor.Subject.TextTrigger.Compact">
        <item name="android:textAppearance">@style/TextAppearance.BinanceMonitor.ControlCompact</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="Widget.BinanceMonitor.Subject.SelectField.Label" parent="">
        <item name="android:minHeight">@dimen/subject_height_md</item>
        <item name="android:gravity">center_vertical|start</item>
        <item name="android:includeFontPadding">false</item>
        <item name="android:maxLines">1</item>
        <item name="android:singleLine">true</item>
        <item name="android:ellipsize">end</item>
        <item name="android:textAppearance">@style/TextAppearance.BinanceMonitor.Control</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:paddingStart">@dimen/field_padding_x</item>
        <item name="android:paddingEnd">@dimen/field_trailing_reserve</item>
        <item name="android:paddingTop">0dp</item>
        <item name="android:paddingBottom">0dp</item>
    </style>

    <style name="Widget.BinanceMonitor.Subject.SelectField.DropdownItem" parent="">
        <item name="android:layout_height">@dimen/subject_height_md</item>
        <item name="android:gravity">center_vertical|start</item>
        <item name="android:includeFontPadding">false</item>
        <item name="android:maxLines">1</item>
        <item name="android:singleLine">true</item>
        <item name="android:ellipsize">end</item>
        <item name="android:textAppearance">@style/TextAppearance.BinanceMonitor.ControlCompact</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:paddingStart">@dimen/field_padding_x</item>
        <item name="android:paddingEnd">@dimen/field_padding_x</item>
        <item name="android:paddingTop">0dp</item>
        <item name="android:paddingBottom">0dp</item>
    </style>

    <style name="Widget.BinanceMonitor.Subject.InputField" parent="Widget.Material3.TextInputLayout.OutlinedBox.Dense">
        <item name="android:minHeight">@dimen/subject_height_md</item>
        <item name="boxBackgroundColor">@color/bg_field_base</item>
        <item name="boxCornerRadiusTopStart">@dimen/radius_md</item>
        <item name="boxCornerRadiusTopEnd">@dimen/radius_md</item>
        <item name="boxCornerRadiusBottomStart">@dimen/radius_md</item>
        <item name="boxCornerRadiusBottomEnd">@dimen/radius_md</item>
        <item name="hintTextColor">@color/text_secondary</item>
        <item name="boxStrokeColor">@android:color/transparent</item>
        <item name="shapeAppearanceOverlay">@style/ShapeAppearanceBinanceMonitorSquare</item>
    </style>

    <style name="Widget.BinanceMonitor.Subject.ToggleChoice" parent="Widget.BinanceMonitor.Subject.TextTrigger.Compact">
        <item name="android:minHeight">@dimen/subject_height_trigger</item>
        <item name="android:textAppearance">@style/TextAppearance.BinanceMonitor.ControlCompact</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="ShapeAppearanceBinanceMonitorSquare">
        <item name="cornerSizeTopLeft">0dp</item>
        <item name="cornerSizeTopRight">0dp</item>
        <item name="cornerSizeBottomLeft">0dp</item>
        <item name="cornerSizeBottomRight">0dp</item>
    </style>
</resources>
