        <item name="android:ellipsize">end</item>
        <item name="android:textAppearance">@style/TextAppearance.BinanceMonitor.Control</item>
        <item name="android:paddingStart">@dimen/space_2</item>
        <item name="android:paddingEnd">@dimen/space_2</item>
        <item name="android:paddingTop">0dp</item>
        <item name="android:paddingBottom">0dp</item>
    </style>

    <style name="Widget.BinanceMonitor.Button.PrimarySquare" parent="Widget.BinanceMonitor.Button.BaseSquare">
