# 生产可直接使用的默认 Caddy 配置。
# 这个版本直接监听 :80，把 MT5 根路径接口和 Binance 代理统一收口到同一个公网入口。

(common_headers) {
    header {
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        Referrer-Policy "no-referrer"
    }
}

:80 {
    import common_headers
    encode gzip

    # 远程账号会话属于高风险接口：没有 HTTPS 时不应对公网暴露。
    # 有域名后请在 Caddyfile.example 的 TLS 站点块中开放，或自行在上游完成 HTTPS 终止后再放行。
    @session path /v2/session/*
    handle @session {
        respond "remote session requires https" 403
    }

    @mt5_root path /health /v1/* /v2/* /openapi.json /docs*
    handle @mt5_root {
        reverse_proxy 127.0.0.1:8787
    }

    handle_path /mt5/* {
        reverse_proxy 127.0.0.1:8787
    }

    basic_auth /admin/* {
        a378910115 $2b$14$G4poTjzSnRuvkj.M87Wi5.qLUyTce4QmGtp34llNXxW2mNPDCAPti
    }

    handle_path /admin/* {
        reverse_proxy 127.0.0.1:8788
    }

    handle_path /binance-rest/* {
        reverse_proxy https://fapi.binance.com {
            header_up Host fapi.binance.com
        }
    }

    handle_path /binance-ws/* {
        reverse_proxy https://fstream.binance.com {
            header_up Host fstream.binance.com
        }
    }

    respond "not found" 404
}
