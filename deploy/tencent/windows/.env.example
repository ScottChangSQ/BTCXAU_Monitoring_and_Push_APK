MT5_LOGIN=12345678
MT5_PASSWORD=your_investor_password
MT5_SERVER=ICMarketsSC-MT5-6
# Optional: terminal64.exe absolute path
# MT5_PATH=C:\Program Files\MetaTrader 5\terminal64.exe
# Optional: comma separated fallback server aliases
# MT5_SERVER_ALIASES=ICMarketsSC-MT5,ICMarketsSC-MT5-5
# Optional: initialize/login timeout (ms)
# MT5_INIT_TIMEOUT_MS=60000

GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8787

# auto: prefer EA push when fresh, fallback to MT5 pull
# pull: always use python MetaTrader5 pull
# ea: only use EA push
GATEWAY_MODE=auto
EA_SNAPSHOT_TTL_SEC=20
# Optional security token for /v1/ea/snapshot
# EA_INGEST_TOKEN=change_me
