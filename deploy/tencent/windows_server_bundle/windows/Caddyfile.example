# 这个样例把 MT5 网关、Binance REST、Binance WebSocket
# 统一暴露在同一个公网入口下。
# 没有域名时保留第一个站点块并替换 PUBLIC_HOST_OR_IP；
# 有域名后删除第一个站点块，启用第二个站点块。

(common_headers) {
    header {
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        Referrer-Policy "no-referrer"
    }
}

http://PUBLIC_HOST_OR_IP {
    import common_headers
    encode gzip

    handle_path /mt5/* {
        reverse_proxy 127.0.0.1:8787
    }

    handle_path /binance-rest/* {
        reverse_proxy https://fapi.binance.com {
            header_up Host fapi.binance.com
        }
    }

    handle_path /binance-ws/* {
        reverse_proxy https://fstream.binance.com {
            header_up Host fstream.binance.com
        }
    }

    respond "not found" 404
}

gateway.example.com {
    import common_headers
    encode gzip
    tls admin@example.com

    header Strict-Transport-Security "max-age=31536000; includeSubDomains"

    handle_path /mt5/* {
        reverse_proxy 127.0.0.1:8787
    }

    handle_path /binance-rest/* {
        reverse_proxy https://fapi.binance.com {
            header_up Host fapi.binance.com
        }
    }

    handle_path /binance-ws/* {
        reverse_proxy https://fstream.binance.com {
            header_up Host fstream.binance.com
        }
    }

    respond "not found" 404
}
